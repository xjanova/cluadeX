<Window x:Class="CluadeX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CluadeX.Views"
        xmlns:vm="clr-namespace:CluadeX.ViewModels"
        xmlns:conv="clr-namespace:CluadeX.Converters"
        Title="CluadeX — AI Coding Assistant"
        Icon="Assets/app.ico"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource CrustBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <!-- Keyboard shortcuts (Claude Code parity) -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="L"
                    Command="{Binding ChatVM.ClearChatCommand}"/>
        <KeyBinding Modifiers="Control" Key="N"
                    Command="{Binding ChatVM.NewSessionCommand}"/>
        <KeyBinding Modifiers="Control" Key="OemComma"
                    Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
        <KeyBinding Modifiers="Control" Key="D1"
                    Command="{Binding NavigateToCommand}" CommandParameter="Chat"/>
        <KeyBinding Modifiers="Control" Key="D2"
                    Command="{Binding NavigateToCommand}" CommandParameter="Models"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- BoolVis is defined globally in App.xaml -->

        <!-- View templates -->
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <views:ChatView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModelManagerViewModel}">
            <views:ModelManagerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PluginManagerViewModel}">
            <views:PluginManagerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PermissionsViewModel}">
            <views:PermissionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskManagerViewModel}">
            <views:TaskManagerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FeaturesViewModel}">
            <views:FeaturesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:McpServersViewModel}">
            <views:McpServersView/>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="RootBorder">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CUSTOM TITLE BAR -->
            <Grid Grid.Row="0" Background="{StaticResource CrustBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Image Source="Assets/logo.png" Width="24" Height="24"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AppVersion, StringFormat='CluadeX {0}'}" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MainFont}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" — AI Coding Assistant" FontSize="11"
                               Foreground="{StaticResource Overlay0Brush}"
                               FontFamily="{StaticResource MainFont}"
                               VerticalAlignment="Center" Margin="2,1,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnMinimize" Style="{StaticResource CaptionButton}"
                            Content="&#xE921;" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Style="{StaticResource CaptionButton}"
                            Content="&#xE922;" Click="BtnMaximize_Click"/>
                    <Button x:Name="BtnClose" Style="{StaticResource CaptionCloseButton}"
                            Content="&#xE8BB;" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- MAIN LAYOUT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource MantleBrush}"
                        BorderThickness="0,0,1,0" BorderBrush="{StaticResource Surface0Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Logo -->
                        <Border Padding="16,14,16,10">
                            <StackPanel Orientation="Horizontal">
                                <!-- Logo with glow effect -->
                                <Border Width="42" Height="42" CornerRadius="21" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#201E90FF" Offset="0"/>
                                            <GradientStop Color="#001E90FF" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                    <Image Source="Assets/logo.png" Width="38" Height="38"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="19" FontWeight="Bold"
                                               FontFamily="{StaticResource MainFont}">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#CDD6F4" Offset="0"/>
                                                <GradientStop Color="#89B4FA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                        CluadeX
                                    </TextBlock>
                                    <TextBlock Text="by Xman Studio" FontSize="9.5"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               Margin="1,-2,0,0" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Row 1: Scrollable area (nav + history + buddy) -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Style="{StaticResource SlimScrollViewer}">
                        <StackPanel>

                        <!-- New Chat + Project buttons -->
                        <Border Padding="8,0,8,6">
                            <StackPanel>
                                <!-- New Chat Button -->
                                <Button Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ChatVM.NewSessionCommand}"
                                        Padding="10,8" Margin="0,0,0,4"
                                        HorizontalContentAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="New Chat"
                                                   FontFamily="{StaticResource MainFont}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Open Folder -->
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ChatVM.OpenFolderCommand}"
                                        Padding="10,7" Margin="0,0,0,2" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13" VerticalAlignment="Center"
                                                   Margin="0,0,8,0" Foreground="{StaticResource TealBrush}"/>
                                        <TextBlock Text="Open Folder" FontFamily="{StaticResource MainFont}"
                                                   FontSize="11.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Navigation -->
                        <StackPanel Margin="8,0,8,4">
                            <RadioButton Content="{Binding NavChat}" Style="{StaticResource NavButton}" Tag="&#xE8BD;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Chat, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Chat"
                                         GroupName="Nav" x:Name="NavChat"/>
                            <RadioButton Content="{Binding NavModels}" Style="{StaticResource NavButton}" Tag="&#xE8F1;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Models, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Models"
                                         GroupName="Nav"/>
                            <RadioButton Content="{Binding NavSettings}" Style="{StaticResource NavButton}" Tag="&#xE713;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Settings, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Settings"
                                         GroupName="Nav"/>

                            <!-- Separator -->
                            <Border Height="1" Background="{StaticResource Surface0Brush}" Margin="4,6"/>

                            <RadioButton Content="{Binding NavPlugins}" Style="{StaticResource NavButton}" Tag="&#xE74C;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Plugins, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Plugins"
                                         GroupName="Nav"/>
                            <RadioButton Content="{Binding NavPermissions}" Style="{StaticResource NavButton}" Tag="&#xE72E;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Permissions, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Permissions"
                                         GroupName="Nav"/>
                            <RadioButton Content="{Binding NavTasks}" Style="{StaticResource NavButton}" Tag="&#xE9D5;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Tasks, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Tasks"
                                         GroupName="Nav"/>
                            <RadioButton Content="{Binding NavMcpServers}" Style="{StaticResource NavButton}" Tag="&#xECAA;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=McpServers, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="McpServers"
                                         GroupName="Nav"/>

                            <!-- Separator -->
                            <Border Height="1" Background="{StaticResource Surface0Brush}" Margin="4,6"/>

                            <RadioButton Content="{Binding NavFeatures}" Style="{StaticResource NavButton}" Tag="&#xE734;"
                                         IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavConverter}, ConverterParameter=Features, Mode=OneWay}"
                                         Command="{Binding NavigateToCommand}" CommandParameter="Features"
                                         GroupName="Nav"/>
                        </StackPanel>

                        <!-- Chat History Header + Search -->
                        <Border Padding="8,8,8,4"
                                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Surface0Brush}">
                            <StackPanel>
                                <Grid Margin="6,0,6,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="{StaticResource Overlay0Brush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="1" Text="CHAT HISTORY"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Search Box -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource Surface0Brush}"
                                            CornerRadius="6" Padding="6,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="11" Foreground="{StaticResource Overlay0Brush}"
                                                       VerticalAlignment="Center" Margin="2,0,6,0"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding ChatVM.HistorySearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextBrush}"
                                                     FontFamily="{StaticResource MainFont}" FontSize="11"
                                                     Padding="0,5" VerticalAlignment="Center"
                                                     CaretBrush="{StaticResource MauveBrush}"/>
                                        </Grid>
                                    </Border>
                                    <!-- Clear search button -->
                                    <Button Grid.Column="1"
                                            Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                            Command="{Binding ChatVM.ClearSearchCommand}"
                                            Style="{StaticResource IconButton}"
                                            Width="24" Height="24"
                                            Opacity="0.4" Margin="2,0,0,0"
                                            ToolTip="Clear search"
                                            Visibility="{Binding ChatVM.IsSearchingHistory, Converter={StaticResource BoolVis}}"/>
                                </Grid>

                                <!-- DB Stats -->
                                <TextBlock Text="{Binding ChatVM.DbStatsText}"
                                           Foreground="{StaticResource Overlay0Brush}"
                                           FontFamily="{StaticResource MainFont}"
                                           FontSize="9" Margin="6,5,6,0"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Border>

                        <!-- Session List / Search Results -->
                        <Grid Margin="0,2,0,0">
                                <!-- Normal session list (hidden during search) -->
                                <ItemsControl ItemsSource="{Binding ChatVM.Sessions}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChatVM.IsSearchingHistory}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ChatVM.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    Style="{StaticResource SessionItemButton}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource Subtext1Brush}"
                                                                   FontFamily="{StaticResource MainFont}"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="165"/>
                                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                                                   Foreground="{StaticResource Overlay0Brush}"
                                                                   FontFamily="{StaticResource MainFont}"
                                                                   FontSize="9.5" Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Delete button -->
                                                    <Button Grid.Column="1"
                                                            Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                            FontSize="9"
                                                            Command="{Binding DataContext.ChatVM.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Id}"
                                                            Style="{StaticResource IconButton}"
                                                            Width="24" Height="24"
                                                            Opacity="0.3"
                                                            ToolTip="Delete session"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty state for sessions -->
                                <TextBlock Text="No conversations yet.&#x0a;Click 'New Chat' to start!"
                                           Foreground="{StaticResource Overlay0Brush}"
                                           FontFamily="{StaticResource MainFont}"
                                           FontSize="11" TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Margin="20,30" Opacity="0.7"
                                           TextAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChatVM.Sessions.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChatVM.IsSearchingHistory}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Search results (shown during search) -->
                                <ItemsControl ItemsSource="{Binding ChatVM.SearchResults}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChatVM.IsSearchingHistory}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ChatVM.LoadSearchResultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding SessionId}"
                                                    Style="{StaticResource SessionItemButton}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding SessionTitle}"
                                                                   Foreground="{StaticResource MauveBrush}"
                                                                   FontFamily="{StaticResource MainFont}"
                                                                   FontSize="11.5" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="155"/>
                                                        <Border Grid.Column="1" Background="{StaticResource Surface1Brush}"
                                                                CornerRadius="8" Padding="5,1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding MatchCount, StringFormat='{}{0} hits'}"
                                                                       Foreground="{StaticResource Overlay1Brush}"
                                                                       FontFamily="{StaticResource MainFont}"
                                                                       FontSize="9"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Snippet}"
                                                               Foreground="{StaticResource Overlay0Brush}"
                                                               FontFamily="{StaticResource MainFont}"
                                                               FontSize="10" Margin="0,3,0,0"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="32"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                                               Foreground="{StaticResource Overlay0Brush}"
                                                               FontFamily="{StaticResource MainFont}"
                                                               FontSize="9" Margin="0,2,0,0" Opacity="0.6"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty state for search results -->
                                <TextBlock Text="No results found."
                                           Foreground="{StaticResource Overlay0Brush}"
                                           FontFamily="{StaticResource MainFont}"
                                           FontSize="11" HorizontalAlignment="Center"
                                           Margin="20,20" Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ChatVM.IsSearchingHistory}" Value="True"/>
                                                        <Condition Binding="{Binding ChatVM.SearchResults.Count}" Value="0"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                        <!-- Buddy Companion Widget -->
                        <Border Padding="8,6" BorderThickness="0,1,0,0"
                                BorderBrush="{StaticResource Surface0Brush}"
                                Visibility="{Binding IsBuddyEnabled, Converter={StaticResource BoolVis}}">
                            <Border Background="{StaticResource Surface0Brush}" CornerRadius="10" Padding="10,8"
                                    Cursor="Hand" MouseLeftButtonDown="Buddy_Pet">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Buddy Emoji -->
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding BuddyService.CurrentBuddy.RarityColor, FallbackValue=#313244}" Opacity="0.25"/>
                                        </Border.Background>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding BuddyService.CurrentBuddy.HatEmoji, FallbackValue=''}"
                                                       FontSize="8" HorizontalAlignment="Center" Margin="0,-2,0,-4"/>
                                            <TextBlock Text="{Binding BuddyService.CurrentBuddy.DisplayEmoji, FallbackValue=🐱}"
                                                       FontSize="20" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Buddy Info -->
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BuddyService.CurrentBuddy.Soul.Name, FallbackValue=Buddy}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="12" FontWeight="Bold"
                                                       FontFamily="{StaticResource MainFont}"/>
                                            <TextBlock Text="{Binding BuddyService.CurrentBuddy.ShinyBadge, FallbackValue=''}"
                                                       FontSize="10" Margin="2,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding BuddyService.CurrentBuddy.RarityStars, FallbackValue=⭐}"
                                                   FontSize="9" Margin="0,1,0,0"/>
                                        <!-- Speech Bubble -->
                                        <TextBlock Text="{Binding BuddyService.CurrentBuddy.SpeechBubble, FallbackValue=''}"
                                                   Foreground="{StaticResource Overlay1Brush}"
                                                   FontSize="10" FontStyle="Italic"
                                                   FontFamily="{StaticResource MainFont}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="130"
                                                   Visibility="{Binding BuddyService.CurrentBuddy.HasSpeech, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Border.ToolTip>
                                    <StackPanel Margin="4">
                                        <TextBlock FontSize="14" FontWeight="Bold" Margin="0,0,0,4">
                                            <Run Text="{Binding BuddyService.CurrentBuddy.DisplayEmoji, Mode=OneWay}"/>
                                            <Run Text="{Binding BuddyService.CurrentBuddy.Soul.Name, Mode=OneWay}"/>
                                            <Run Text="{Binding BuddyService.CurrentBuddy.ShinyBadge, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding BuddyService.CurrentBuddy.RarityStars}" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <Run Text="Species: "/><Run Text="{Binding BuddyService.CurrentBuddy.Bones.Species, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <Run Text="Personality: "/><Run Text="{Binding BuddyService.CurrentBuddy.Soul.Personality, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Border Height="1" Background="Gray" Opacity="0.3" Margin="0,6"/>
                                        <TextBlock FontSize="11" Foreground="Gray" Text="📊 Stats" FontWeight="SemiBold" Margin="0,2,0,2"/>
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="🔧 Debugging: "/><Run Text="{Binding BuddyService.CurrentBuddy.Bones.Stats.Debugging, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="🧘 Patience: "/><Run Text="{Binding BuddyService.CurrentBuddy.Bones.Stats.Patience, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="🌀 Chaos: "/><Run Text="{Binding BuddyService.CurrentBuddy.Bones.Stats.Chaos, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="📖 Wisdom: "/><Run Text="{Binding BuddyService.CurrentBuddy.Bones.Stats.Wisdom, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="😏 Snark: "/><Run Text="{Binding BuddyService.CurrentBuddy.Bones.Stats.Snark, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Border Height="1" Background="Gray" Opacity="0.3" Margin="0,6"/>
                                        <TextBlock FontSize="10" Foreground="Gray" FontStyle="Italic" Text="Click to pet! 💕"/>
                                    </StackPanel>
                                </Border.ToolTip>
                            </Border>
                        </Border>

                        </StackPanel>
                        </ScrollViewer>

                        <!-- Row 2: Bottom Status (pinned) -->
                        <Border Grid.Row="2" Padding="14,10" BorderThickness="0,1,0,0"
                                BorderBrush="{StaticResource Surface0Brush}">
                            <StackPanel>
                                <!-- Project Name -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5"
                                            Visibility="{Binding ChatVM.HasProject, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="{StaticResource TealBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding ChatVM.ProjectName}"
                                               Foreground="{StaticResource TealBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" MaxWidth="175"/>
                                </StackPanel>

                                <!-- Model Status -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource RedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsModelLoaded}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsModelLoading}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource YellowBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ModelStatus}"
                                               Foreground="{StaticResource Subtext0Brush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"
                                               MaxWidth="175"/>
                                </StackPanel>

                                <!-- GPU Status -->
                                <TextBlock Text="{Binding GpuStatus}"
                                           Foreground="{StaticResource Overlay0Brush}"
                                           FontSize="10" TextTrimming="CharacterEllipsis"/>

                                <!-- Version + Check Update -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding AppVersion}"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontSize="10" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Style="{StaticResource IconButton}"
                                            Command="{Binding CheckUpdateCommand}"
                                            ToolTip="Check for updates"
                                            Padding="4,2" Opacity="0.7">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{StaticResource BlueBrush}"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="Update" FontSize="10"
                                                       Foreground="{StaticResource BlueBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- UPDATE NOTIFICATION BAR -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Update bar (slides in when update available) -->
                    <Border Grid.Row="0" Padding="12,8"
                            Visibility="{Binding ShowUpdateBar, Converter={StaticResource BoolVis}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1A6366F1" Offset="0"/>
                                <GradientStop Color="#1A06B6D4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Update icon -->
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <!-- Message + progress -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UpdateMessage}"
                                           Foreground="{StaticResource TextBrush}" FontSize="12"/>
                                <ProgressBar Value="{Binding UpdateProgress}" Maximum="100"
                                             Height="4" Margin="0,4,0,0"
                                             Style="{StaticResource ContextProgressBar}"
                                             Foreground="{StaticResource BlueBrush}"
                                             Visibility="{Binding IsUpdating, Converter={StaticResource BoolVis}}"/>
                                <TextBlock Text="{Binding UpdateProgressText}"
                                           Foreground="{StaticResource Overlay0Brush}" FontSize="10"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding IsUpdating, Converter={StaticResource BoolVis}}"/>
                            </StackPanel>

                            <!-- Install button -->
                            <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding InstallUpdateCommand}"
                                    Padding="14,5" Margin="8,0" FontSize="11">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Install &amp; Restart" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Dismiss -->
                            <Button Grid.Column="3" Style="{StaticResource IconButton}"
                                    Command="{Binding DismissUpdateCommand}"
                                    ToolTip="Dismiss" Padding="4">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource Overlay0Brush}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- MAIN CONTENT -->
                    <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
                </Grid>
            </Grid>
            <!-- ═══════ MODEL LOADING OVERLAY ═══════ -->
            <Border Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="999"
                    Visibility="{Binding IsModelLoading, Converter={StaticResource BoolVis}}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource CrustColor}" Opacity="0.85"/>
                </Border.Background>

                <!-- Center card -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{StaticResource Surface0Brush}"
                        CornerRadius="16" Padding="40,36"
                        MinWidth="380">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Spinning icon -->
                        <Border Width="64" Height="64"
                                Background="{StaticResource Surface1Brush}"
                                CornerRadius="32" Margin="0,0,0,20"
                                HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="28" Foreground="{StaticResource MauveBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="SpinTransform" Angle="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModelLoading}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="SpinStoryboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                From="0" To="360" Duration="0:0:1.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="SpinStoryboard"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="Loading Model"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="20" FontWeight="Bold"
                                   FontFamily="{StaticResource MainFont}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- Status text -->
                        <TextBlock Text="{Binding ModelStatus}"
                                   Foreground="{StaticResource Subtext0Brush}"
                                   FontSize="13"
                                   FontFamily="{StaticResource MainFont}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="320"
                                   Margin="0,0,0,16"/>

                        <!-- Indeterminate progress bar -->
                        <ProgressBar IsIndeterminate="True"
                                     Style="{StaticResource ModernProgressBar}"
                                     Height="4" Width="260"
                                     Foreground="{StaticResource MauveBrush}"
                                     HorizontalAlignment="Center"/>

                        <!-- Hint -->
                        <TextBlock Text="Please wait while the model loads into memory..."
                                   Foreground="{StaticResource Overlay0Brush}"
                                   FontSize="11"
                                   FontFamily="{StaticResource MainFont}"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
