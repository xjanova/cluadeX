<UserControl x:Class="CluadeX.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CluadeX.Converters"
             xmlns:vm="clr-namespace:CluadeX.ViewModels"
             xmlns:services="clr-namespace:CluadeX.Services">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,20,0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource SlimScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24" MaxWidth="700">

            <!-- Page Title -->
            <TextBlock Text="{services:Loc settings.title}" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       FontFamily="{StaticResource MainFont}" Margin="0,0,0,4"/>
            <TextBlock Text="{services:Loc settings.subtitle}"
                       Foreground="{StaticResource Subtext0Brush}" FontSize="13" Margin="0,0,0,8"/>

            <!-- Save Status -->
            <TextBlock Text="{Binding SaveStatus}" Foreground="{StaticResource GreenBrush}"
                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <!-- ═══════ AI PROVIDER ═══════ -->
            <TextBlock Text="{services:Loc settings.provider}" Style="{StaticResource SectionTitle}" Margin="0,4,0,12"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Provider Selection -->
                    <TextBlock Text="{services:Loc settings.activeProvider}" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="{services:Loc settings.providerChoose}"
                               Style="{StaticResource SettingDesc}"/>
                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                              SelectedItem="{Binding SelectedProvider}"
                              Style="{StaticResource ModernComboBox}"
                              Width="250" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                    <!-- Local GGUF notice -->
                    <TextBlock Text="{services:Loc settings.localGgufNotice}"
                               Foreground="{StaticResource TealBrush}" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Visibility="{Binding IsLocalSelected, Converter={StaticResource BoolVis}}"/>

                    <!-- API Key (visible for OpenAI, Anthropic, Gemini) -->
                    <StackPanel Visibility="{Binding NeedsApiKey, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{services:Loc settings.apiKey}" Style="{StaticResource SettingLabel}"/>
                        <TextBlock Style="{StaticResource SettingDesc}" Text="{services:Loc settings.apiKeyDesc}"/>
                        <TextBlock Margin="0,0,0,8" FontSize="11">
                            <Hyperlink NavigateUri="{Binding ApiKeyLink}" RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="{StaticResource BlueBrush}">
                                <Run Text="{Binding ApiKeyLinkText, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Masked display (read-only) shown when ShowApiKey = false -->
                            <TextBox Grid.Column="0"
                                     Text="{Binding MaskedApiKey, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource ModernTextBox}"
                                     Visibility="{Binding ShowApiKey, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"/>
                            <!-- Editable real key shown when ShowApiKey = true -->
                            <TextBox Grid.Column="0"
                                     Text="{Binding ProviderApiKey, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Visibility="{Binding ShowApiKey, Converter={StaticResource BoolVis}}"/>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding ShowApiKey}"
                                          Margin="8,0,0,0"
                                          Padding="12,0"
                                          MinWidth="72"
                                          VerticalAlignment="Stretch"
                                          ToolTip="{services:Loc settings.apiKeyToggleTooltip}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{services:Loc settings.apiKeyShow}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowApiKey}" Value="True">
                                                    <Setter Property="Text" Value="{services:Loc settings.apiKeyHide}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ToggleButton>
                        </Grid>
                    </StackPanel>

                    <!-- Base URL (visible for all except Local) -->
                    <StackPanel Visibility="{Binding SupportsBaseUrl, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{services:Loc settings.baseUrl}" Style="{StaticResource SettingLabel}"/>
                        <TextBlock Text="{services:Loc settings.baseUrlDesc}"
                                   Style="{StaticResource SettingDesc}"/>
                        <TextBox Text="{Binding ProviderBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                    </StackPanel>

                    <!-- Model Selection (not shown for Local) -->
                    <StackPanel Visibility="{Binding IsLocalSelected, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
                        <TextBlock Text="{services:Loc settings.model}" Style="{StaticResource SettingLabel}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding AvailableModels}"
                                      SelectedItem="{Binding ProviderModel}"
                                      Text="{Binding ProviderModel, UpdateSourceTrigger=LostFocus}"
                                      IsEditable="True"
                                      Style="{StaticResource ModernComboBox}"
                                      HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1" Content="&#xE72C;" Style="{StaticResource IconButton}"
                                    FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding RefreshOllamaModelsCommand}"
                                    ToolTip="{services:Loc settings.refreshModels}"
                                    Visibility="{Binding IsOllamaSelected, Converter={StaticResource BoolVis}}"
                                    Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Custom Model ID -->
                        <CheckBox Content="{services:Loc settings.useCustomModel}" IsChecked="{Binding UseCustomModel}"
                                  Margin="0,4,0,4"/>
                        <TextBox Text="{Binding ProviderCustomModel, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 IsEnabled="{Binding UseCustomModel}"
                                 Margin="0,0,0,16"/>
                    </StackPanel>

                    <!-- Test Connection + Apply -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8"
                                Visibility="{Binding IsLocalSelected, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
                        <Button Content="{services:Loc settings.testConnection}" Style="{StaticResource SecondaryButton}"
                                Command="{Binding TestConnectionCommand}" Margin="0,0,12,0"/>
                        <Button Content="{services:Loc settings.applyProvider}" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApplyProviderCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ConnectionTestResult}"
                               Foreground="{StaticResource TealBrush}" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                </StackPanel>
            </Border>

            <!-- ═══════ GPU INFO ═══════ -->
            <TextBlock Text="{services:Loc settings.gpuInfo}" Style="{StaticResource SectionTitle}"/>
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding GpuInfoDisplay}" Foreground="{StaticResource TextBrush}"
                                   FontSize="13" FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding VramRecommendation}" Foreground="{StaticResource TealBrush}"
                                   FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#xE72C;" Style="{StaticResource IconButton}"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{Binding RefreshGpuCommand}"
                            VerticalAlignment="Top" ToolTip="{services:Loc settings.refreshGpu}"/>
                </Grid>
            </Border>

            <!-- ═══════ BACKEND SETTINGS ═══════ -->
            <TextBlock Text="{services:Loc settings.backend}" Style="{StaticResource SectionTitle}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <!-- GPU Backend -->
                    <TextBlock Text="{services:Loc settings.gpuBackend}" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="{services:Loc settings.gpuBackendDesc}" Style="{StaticResource SettingDesc}"/>
                    <ComboBox ItemsSource="{Binding BackendOptions}"
                              SelectedItem="{Binding GpuBackend}"
                              Style="{StaticResource ModernComboBox}"
                              Width="200" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                    <!-- GPU Layers -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="{services:Loc settings.gpuLayers}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding GpuLayerCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{services:Loc settings.gpuLayersDesc}" Style="{StaticResource SettingDesc}"/>
                    <TextBox Text="{Binding GpuLayerCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                    <!-- Batch Size -->
                    <TextBlock Text="{services:Loc settings.batchSize}" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="{services:Loc settings.batchSizeDesc}" Style="{StaticResource SettingDesc}"/>
                    <ComboBox ItemsSource="{Binding BatchSizeOptions}"
                              SelectedItem="{Binding BatchSize}"
                              Style="{StaticResource ModernComboBox}"
                              Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                    <!-- Thread Count -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="{services:Loc settings.cpuThreads}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding ThreadCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{services:Loc settings.cpuThreadsDesc}" Style="{StaticResource SettingDesc}"/>
                    <TextBox Text="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Width="120" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ═══════ DIRECTORIES ═══════ -->
            <TextBlock Text="{services:Loc settings.directories}" Style="{StaticResource SectionTitle}"/>

            <!-- Portable Mode Info -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                    Visibility="{Binding IsPortable, Converter={StaticResource BoolVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8CE;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource TealBrush}" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Foreground="{StaticResource TealBrush}" FontSize="12" TextWrapping="Wrap">
                        <Run Text="{services:Loc settings.portableMode}" FontWeight="SemiBold"/>
                        <Run Text=" - "/>
                        <Run Text="{Binding DataRootDisplay, Mode=OneWay}" FontFamily="{StaticResource MonoFont}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Model Directory -->
            <TextBlock Text="{services:Loc settings.modelStorageDir}" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="{services:Loc settings.modelStorageDirDesc}" Style="{StaticResource SettingDesc}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding ModelDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>
                <Button Grid.Column="1" Content="&#xED25;" Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding BrowseModelDirCommand}" Margin="4,0" ToolTip="Browse"/>
                <Button Grid.Column="2" Content="&#xE838;" Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding OpenDirectoryCommand}"
                        CommandParameter="{Binding ModelDirectory}" ToolTip="Open folder"/>
            </Grid>

            <!-- Cache Directory -->
            <TextBlock Text="{services:Loc settings.cacheDir}" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="{services:Loc settings.cacheDirDesc}" Style="{StaticResource SettingDesc}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding CacheDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>
                <Button Grid.Column="1" Content="&#xED25;" Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding BrowseCacheDirCommand}" Margin="4,0"/>
            </Grid>

            <!-- Log Directory -->
            <TextBlock Text="{services:Loc settings.logDir}" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="{services:Loc settings.logDirDesc}" Style="{StaticResource SettingDesc}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding LogDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>
                <Button Grid.Column="1" Content="&#xED25;" Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding BrowseLogDirCommand}" Margin="4,0"/>
            </Grid>

            <!-- Temp Directory -->
            <TextBlock Text="{services:Loc settings.tempDir}" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="{services:Loc settings.tempDirDesc}" Style="{StaticResource SettingDesc}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding TempDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>
                <Button Grid.Column="1" Content="&#xED25;" Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding BrowseTempDirCommand}" Margin="4,0"/>
            </Grid>

            <!-- ═══════ INFERENCE ═══════ -->
            <TextBlock Text="{services:Loc settings.inference}" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- Context Size -->
                    <StackPanel Margin="0,0,12,16">
                        <TextBlock Text="{services:Loc settings.contextSize}" Style="{StaticResource SettingLabel}"/>
                        <TextBlock Text="{services:Loc settings.contextSizeDesc}" Style="{StaticResource SettingDesc}"/>
                        <ComboBox ItemsSource="{Binding ContextSizeOptions}"
                                  SelectedItem="{Binding ContextSize}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="150" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Max Tokens -->
                    <StackPanel Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Text="{services:Loc settings.maxOutputTokens}" Style="{StaticResource SettingLabel}"/>
                        <TextBlock Text="{services:Loc settings.maxOutputTokensDesc}" Style="{StaticResource SettingDesc}"/>
                        <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Width="150" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Temperature -->
                    <StackPanel Grid.Row="1" Margin="0,0,12,16">
                        <TextBlock Style="{StaticResource SettingLabel}">
                            <Run Text="{services:Loc settings.temperature}"/><Run Text=": "/><Run Text="{Binding Temperature, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{services:Loc settings.temperatureDesc}" Style="{StaticResource SettingDesc}"/>
                        <Slider Value="{Binding Temperature}" Minimum="0" Maximum="2" TickFrequency="0.1"
                                IsSnapToTickEnabled="True"/>
                    </StackPanel>

                    <!-- Top P -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Style="{StaticResource SettingLabel}">
                            <Run Text="Top P: "/><Run Text="{Binding TopP, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{services:Loc settings.topPDesc}" Style="{StaticResource SettingDesc}"/>
                        <Slider Value="{Binding TopP}" Minimum="0" Maximum="1" TickFrequency="0.05"
                                IsSnapToTickEnabled="True"/>
                    </StackPanel>

                    <!-- Repeat Penalty -->
                    <StackPanel Grid.Row="2" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource SettingLabel}">
                            <Run Text="Repeat Penalty: "/><Run Text="{Binding RepeatPenalty, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{services:Loc settings.repetitionPenaltyDesc}" Style="{StaticResource SettingDesc}"/>
                        <Slider Value="{Binding RepeatPenalty}" Minimum="1" Maximum="2" TickFrequency="0.05"
                                IsSnapToTickEnabled="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════ ANTHROPIC ADVANCED ═══════ -->
            <TextBlock Text="{services:Loc settings.anthropicAdvanced}" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <CheckBox Content="{services:Loc settings.extendedThinking}" IsChecked="{Binding ExtendedThinkingEnabled}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="Enable Claude's extended thinking mode for complex reasoning. Uses additional tokens for internal reasoning before responding."
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" Margin="30,0,0,12" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="30,0,0,8">
                        <TextBlock Text="Thinking Budget: " VerticalAlignment="Center"/>
                        <TextBox Text="{Binding ThinkingBudgetTokens, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" Margin="4,0,8,0"/>
                        <TextBlock Text="tokens" VerticalAlignment="Center"
                                   Foreground="{StaticResource Overlay0Brush}"/>
                    </StackPanel>

                    <CheckBox Content="{services:Loc settings.promptCaching}" IsChecked="{Binding PromptCachingEnabled}"
                              Margin="0,12,0,4"/>
                    <TextBlock Text="Cache the system prompt across API calls to reduce costs. Recommended for Anthropic."
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" Margin="30,0,0,12" TextWrapping="Wrap"/>

                    <CheckBox Content="{services:Loc settings.microcompact}" IsChecked="{Binding MicrocompactEnabled}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{services:Loc settings.microcompactDesc}"
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" Margin="30,0,0,12" TextWrapping="Wrap"/>

                    <CheckBox Content="{services:Loc settings.sessionMemory}" IsChecked="{Binding SessionMemoryEnabled}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{services:Loc settings.sessionMemoryDesc}"
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" Margin="30,0,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══════ AGENT ═══════ -->
            <TextBlock Text="{services:Loc settings.agent}" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <CheckBox Content="Auto-Execute Code" IsChecked="{Binding AutoExecuteCode}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="When enabled, CluadeX will automatically run generated code and fix errors."
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" Margin="30,0,0,16" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Max Auto-Fix Attempts:" Foreground="{StaticResource TextBrush}"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Text="{Binding MaxAutoFixAttempts, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Width="60"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Preferred Language:" Foreground="{StaticResource TextBrush}"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding PreferredLanguage}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="150"/>
                    </StackPanel>

                    <!-- UI Language / ภาษา -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="🌐 Language / ภาษา:" Foreground="{StaticResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox ItemsSource="{Binding UiLanguageOptions}"
                                  SelectedItem="{Binding UiLanguage}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="150"/>
                        <TextBlock Text="(เปลี่ยนภาษาทั้งโปรแกรม)" Foreground="{StaticResource Overlay0Brush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <CheckBox Content="Stream Output (show tokens as they generate)" IsChecked="{Binding StreamOutput}"/>
                </StackPanel>
            </Border>

            <!-- ═══════ HUGGINGFACE ═══════ -->
            <TextBlock Text="{services:Loc settings.huggingface}" Style="{StaticResource SectionTitle}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="API Token (optional)" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="Required only for private or gated models. Get your token from huggingface.co/settings/tokens" Style="{StaticResource SettingDesc}"/>
                    <TextBox Text="{Binding HuggingFaceToken, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
            </Border>

            <!-- ═══════ MEMORY MANAGEMENT ═══════ -->
            <TextBlock Text="{services:Loc settings.memoryMgmt}" Style="{StaticResource SectionTitle}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Persistent memories saved by the AI agent. These survive across chat sessions."
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <!-- Memory List -->
                    <ListBox ItemsSource="{Binding Memories}" SelectedItem="{Binding SelectedMemory}"
                             Background="Transparent" BorderThickness="0"
                             MaxHeight="200" Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Border Background="{StaticResource Surface0Brush}" CornerRadius="3"
                                            Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MauveBrush}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                    <Border Background="{StaticResource Surface0Brush}" CornerRadius="3"
                                            Padding="4,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Scope}" FontSize="9"
                                                   Foreground="{StaticResource Subtext0Brush}"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Selected Memory Preview -->
                    <TextBox Text="{Binding SelectedMemoryContent, Mode=OneWay}" IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"
                             TextWrapping="Wrap" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8" FontSize="11"
                             Visibility="{Binding SelectedMemory, Converter={StaticResource NullToCollapsed}}"/>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding RefreshMemoriesCommand}"
                                Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{services:Loc settings.refresh}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding DeleteMemoryCommand}"
                                Padding="8,4" Foreground="{StaticResource RedBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{services:Loc settings.deleteSelected}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding MemoryStatusText}" Foreground="{StaticResource Subtext0Brush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════ BUTTONS ═══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,24" VerticalAlignment="Center">
                <Button Content="💾 Save Settings" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" Margin="0,0,12,0"/>
                <Button Content="{services:Loc settings.resetDefaults}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ResetDefaultsCommand}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"
                        Command="{Binding DataContext.CheckUpdateCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{services:Loc settings.checkUpdates}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- Save feedback next to buttons -->
                <TextBlock Text="{Binding SaveStatus}" Foreground="{StaticResource GreenBrush}"
                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
