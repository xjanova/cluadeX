<UserControl x:Class="CluadeX.Views.ModelManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CluadeX.Converters"
             xmlns:vm="clr-namespace:CluadeX.ViewModels">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:FileSizeConverter x:Key="FileSize"/>
        <conv:InverseBoolConverter x:Key="InvertBool"/>

        <!-- Tag badge style -->
        <Style x:Key="TagBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <!-- Accent tag badge (quantization) -->
        <Style x:Key="QuantBadge" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{StaticResource MauveColor}" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="SizeBadge" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{StaticResource TealColor}" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <!-- Source card hover -->
        <Style x:Key="SourceCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="{StaticResource Surface1Color}"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource SlimScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- Page Header -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Model Manager" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MainFont}"/>
                    <TextBlock Text="Download, browse, and load AI models for local inference"
                               Foreground="{StaticResource Subtext0Brush}" FontSize="13" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE838;" Style="{StaticResource IconButton}"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Command="{Binding OpenModelFolderCommand}"
                            ToolTip="Open model folder" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding BrowseAndLoadModelCommand}"
                            Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Load GGUF File" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- GPU Info Card -->
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource Surface1Brush}" CornerRadius="8"
                            Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource TealBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="GPU Status" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding GpuRecommendation}"
                                   Foreground="{StaticResource Subtext0Brush}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Download Progress -->
            <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding DownloadStatus}"
                                   Foreground="{StaticResource TextBrush}" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Cancel" Style="{StaticResource DangerButton}"
                                Command="{Binding CancelDownloadCommand}" Padding="12,4" FontSize="12"/>
                    </Grid>
                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="100"
                                 Style="{StaticResource ModernProgressBar}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Status Message (non-downloading) -->
            <TextBlock Text="{Binding DownloadStatus}" Foreground="{StaticResource Subtext0Brush}"
                       FontSize="12" Margin="0,6,0,0"
                       Visibility="{Binding IsDownloading, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DownloadStatus}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Model Load Status -->
            <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                    Visibility="{Binding IsLoadingModel, Converter={StaticResource BoolVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding ModelLoadStatus}" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- ═══════ TAB NAVIGATION ═══════ -->
            <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource Surface0Brush}"
                    Margin="0,16,0,0" Padding="0,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Recommended" Style="{StaticResource NavButton}" Tag="&#xE735;"
                                 IsChecked="True" GroupName="ModelTabs" x:Name="RecommendedTab"/>
                    <RadioButton Content="My Models" Style="{StaticResource NavButton}" Tag="&#xE8B7;"
                                 GroupName="ModelTabs" x:Name="LocalTab"/>
                    <RadioButton Content="Search HuggingFace" Style="{StaticResource NavButton}" Tag="&#xE721;"
                                 GroupName="ModelTabs" x:Name="SearchTab"/>
                    <RadioButton Content="Where to Get Models" Style="{StaticResource NavButton}" Tag="&#xE774;"
                                 GroupName="ModelTabs" x:Name="SourcesTab"/>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- RECOMMENDED MODELS TAB                                 -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsChecked, ElementName=RecommendedTab, Converter={StaticResource BoolVis}}"
                        Margin="0,16,0,0">

                <!-- Category Filter + List/Grid Toggle -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Popular Models for Your GPU" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" FontSize="15"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- List/Grid view switch -->
                        <Border CornerRadius="6" Background="{StaticResource Surface0Brush}"
                                Padding="2" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton IsChecked="{Binding IsListView, Mode=OneWay}"
                                              Command="{Binding SwitchToListViewCommand}"
                                              ToolTip="List view"
                                              Padding="8,4" MinWidth="32"
                                              Background="Transparent" BorderThickness="0"
                                              Content="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="12">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource MauveBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding IsGridView, Mode=OneWay}"
                                              Command="{Binding SwitchToGridViewCommand}"
                                              ToolTip="Grid view"
                                              Padding="8,4" MinWidth="32"
                                              Background="Transparent" BorderThickness="0"
                                              Content="&#xF0E2;" FontFamily="Segoe MDL2 Assets" FontSize="12">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource MauveBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Category:" Foreground="{StaticResource Overlay0Brush}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="120"/>
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding RecommendedModels}">
                    <!-- Swap the panel based on IsGridView: stack vs 2-column uniform grid -->
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="ItemsPanel">
                                <Setter.Value>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGridView}" Value="True">
                                    <Setter Property="ItemsPanel">
                                        <Setter.Value>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" CornerRadius="10"
                                    Background="{StaticResource Surface0Brush}"
                                    Padding="12"
                                    BorderThickness="2"
                                    ToolTip="{Binding FitHint}">
                                <!-- Left-edge accent colored by fit tier -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Green">
                                                <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Teal">
                                                <Setter Property="BorderBrush" Value="{StaticResource TealBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Yellow">
                                                <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Peach">
                                                <Setter Property="BorderBrush" Value="{StaticResource PeachBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Red">
                                                <Setter Property="BorderBrush" Value="{StaticResource RedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" FontSize="14"/>
                                            <!-- Category badge -->
                                            <Border Style="{StaticResource TagBadge}" Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Category}" FontSize="10"
                                                           Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                            <!-- Parameter badge -->
                                            <Border Style="{StaticResource SizeBadge}" VerticalAlignment="Center">
                                                <TextBlock FontSize="10" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold">
                                                    <Run Text="{Binding ParameterBillions}"/><Run Text="B"/>
                                                </TextBlock>
                                            </Border>
                                            <!-- Fit badge — colored pill telling the user how this model runs on their GPU -->
                                            <Border VerticalAlignment="Center" Margin="4,0,0,0"
                                                    CornerRadius="4" Padding="7,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Green">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Teal">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{StaticResource TealColor}" Opacity="0.2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Yellow">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Peach">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{StaticResource PeachColor}" Opacity="0.2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FitColorKey}" Value="Red">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{StaticResource RedColor}" Opacity="0.2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding FitLabel}" FontSize="10" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FitColorKey}" Value="Green">
                                                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FitColorKey}" Value="Teal">
                                                                    <Setter Property="Foreground" Value="{StaticResource TealBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FitColorKey}" Value="Yellow">
                                                                    <Setter Property="Foreground" Value="{StaticResource YellowBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FitColorKey}" Value="Peach">
                                                                    <Setter Property="Foreground" Value="{StaticResource PeachBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FitColorKey}" Value="Red">
                                                                    <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <!-- Installed badge -->
                                            <Border VerticalAlignment="Center" Margin="4,0,0,0"
                                                    CornerRadius="4" Padding="7,2"
                                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolVis}}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.15"/>
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x2713;" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource GreenBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                    <TextBlock Text="Installed" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource GreenBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource Subtext0Brush}"
                                                   FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <!-- Star rating -->
                                            <TextBlock Text="{Binding StarDisplay}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="11">
                                                <Run Text="VRAM: "/><Run Text="{Binding RequiredVramMB, StringFormat='{}{0:N0} MB'}"/>
                                                <Run Text="  |  Size: "/>
                                                <Run Text="{Binding ApproxSizeBytes, Converter={StaticResource FileSize}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Button Content="&#xE774;" Style="{StaticResource IconButton}"
                                                FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Url}"
                                                ToolTip="View on HuggingFace" Margin="0,0,6,0"/>
                                        <!-- Load button (shown when installed) -->
                                        <Button Content="Load"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DataContext.LoadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding InstalledPath}"
                                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolVis}}"
                                                Padding="16,8"/>
                                        <!-- Download button (shown when NOT installed) -->
                                        <Button Content="Download"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.DownloadRecommendedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.IsDownloading, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InvertBool}}"
                                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"
                                                Padding="16,8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pagination Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,4">
                    <Button Content="◀ Prev" Style="{StaticResource SecondaryButton}"
                            Command="{Binding PrevPageCommand}" Padding="12,4" FontSize="11"/>
                    <TextBlock Text="{Binding PageInfo}" Foreground="{StaticResource TextBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="16,0" FontFamily="{StaticResource MonoFont}"/>
                    <Button Content="Next ▶" Style="{StaticResource SecondaryButton}"
                            Command="{Binding NextPageCommand}" Padding="12,4" FontSize="11"/>
                </StackPanel>

                <!-- Empty state for filtered -->
                <TextBlock Text="No models match this category for your GPU VRAM."
                           Foreground="{StaticResource Overlay0Brush}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,20" FontStyle="Italic">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecommendedModels.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- LOCAL MODELS TAB                                       -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsChecked, ElementName=LocalTab, Converter={StaticResource BoolVis}}"
                        Margin="0,16,0,0">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Downloaded Models" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" FontSize="15"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddModelDirectoryCommand}"
                                Margin="0,0,6,0" Padding="10,6" ToolTip="Scan another folder for GGUF files">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Add Folder" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Unload" Style="{StaticResource SecondaryButton}"
                                Command="{Binding UnloadModelCommand}" Margin="0,0,6,0" Padding="12,6"/>
                        <Button Content="Refresh" Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshLocalModelsCommand}" Padding="12,6"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding ModelLoadStatus}" Foreground="{StaticResource Subtext0Brush}"
                           FontSize="12" Margin="0,0,0,8"/>

                <ItemsControl ItemsSource="{Binding LocalModels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" FontSize="14"/>
                                            <!-- Quant badge -->
                                            <Border Style="{StaticResource QuantBadge}" Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding QuantizationType, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding QuantizationType}" FontSize="10"
                                                           Foreground="{StaticResource MauveBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                            <!-- Param size badge -->
                                            <Border Style="{StaticResource SizeBadge}" VerticalAlignment="Center"
                                                    Visibility="{Binding ParameterDisplay, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding ParameterDisplay}" FontSize="10"
                                                           Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding FileSizeDisplay}"
                                                       Foreground="{StaticResource Overlay0Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding LocalPath}" Foreground="{StaticResource Overlay0Brush}"
                                                   FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"
                                                   FontFamily="{StaticResource MonoFont}" Opacity="0.7"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Load" Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DataContext.LoadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding LocalPath}"
                                                Padding="14,8" Margin="0,0,6,0"/>
                                        <Button Content="&#xE74D;" Style="{StaticResource DangerButton}"
                                                FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding DataContext.DeleteModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="10,8" ToolTip="Delete model"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <Border Margin="0,8,0,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LocalModels.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" Margin="0,16">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                   Foreground="{StaticResource Overlay0Brush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="No models found" Foreground="{StaticResource Subtext0Brush}"
                                   FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,12" TextAlignment="Center">
                            Download a model from the Recommended tab, or click
                            <Bold>"Load GGUF File"</Bold> above to load any .gguf file from your computer.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding BrowseAndLoadModelCommand}" Padding="14,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Browse for GGUF File" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AddModelDirectoryCommand}"
                                    Margin="8,0,0,0" Padding="14,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Add Model Folder" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- SEARCH HUGGINGFACE TAB                                 -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsChecked, ElementName=SearchTab, Converter={StaticResource BoolVis}}"
                        Margin="0,16,0,0">
                <TextBlock Text="Search HuggingFace for GGUF Models" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="12" Margin="0,0,0,12">
                    Search for any model. Try: "codellama", "deepseek coder", "qwen", "mistral", "phi"
                </TextBlock>

                <!-- Search Bar -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             FontSize="14"
                             x:Name="SearchBox"
                             KeyDown="SearchBox_KeyDown"/>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchModelsCommand}"
                            IsEnabled="{Binding IsSearching, Converter={StaticResource InvertBool}}"
                            Margin="8,0,0,0" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Search" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Search Status -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding IsSearching, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Searching HuggingFace..." Foreground="{StaticResource BlueBrush}"
                               FontSize="13"/>
                </StackPanel>

                <!-- Search Result Info -->
                <TextBlock Text="{Binding SearchResultInfo}" Foreground="{StaticResource Subtext0Brush}"
                           FontSize="12" Margin="0,0,0,8"
                           Visibility="{Binding SearchResultInfo, Converter={StaticResource BoolVis}}"/>

                <!-- Search Results -->
                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <!-- Repo name -->
                                        <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13">
                                            <Run Text="{Binding Author}" Foreground="{StaticResource Overlay0Brush}"/><Run Text="/" Foreground="{StaticResource Overlay0Brush}"/><Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"/>
                                        </TextBlock>

                                        <!-- File name with badges -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{StaticResource BlueBrush}"
                                                       FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                       VerticalAlignment="Center"/>
                                            <!-- Installed badge -->
                                            <Border VerticalAlignment="Center" Margin="8,0,0,0"
                                                    CornerRadius="4" Padding="7,2"
                                                    Visibility="{Binding IsDownloaded, Converter={StaticResource BoolVis}}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.15"/>
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x2713;" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource GreenBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                    <TextBlock Text="Installed" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource GreenBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Badges row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <!-- File size -->
                                            <Border Style="{StaticResource SizeBadge}"
                                                    Visibility="{Binding FileSize, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding FileSizeDisplay}" FontSize="10"
                                                           Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                            <!-- Quantization -->
                                            <Border Style="{StaticResource QuantBadge}"
                                                    Visibility="{Binding QuantizationType, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding QuantizationType}" FontSize="10"
                                                           Foreground="{StaticResource MauveBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                            <!-- Param size -->
                                            <Border Style="{StaticResource TagBadge}"
                                                    Visibility="{Binding ParameterDisplay, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding ParameterDisplay}" FontSize="10"
                                                           Foreground="{StaticResource PeachBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                            <!-- Downloads -->
                                            <Border Style="{StaticResource TagBadge}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="9" Foreground="{StaticResource Overlay0Brush}"
                                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                    <TextBlock Text="{Binding DownloadsDisplay}" FontSize="10"
                                                               Foreground="{StaticResource Overlay0Brush}"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Likes -->
                                            <Border Style="{StaticResource TagBadge}"
                                                    Visibility="{Binding Likes, Converter={StaticResource BoolVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEB52;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="9" Foreground="{StaticResource RedBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                    <TextBlock Text="{Binding LikesDisplay}" FontSize="10"
                                                               Foreground="{StaticResource Overlay0Brush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Read more on HuggingFace -->
                                        <Button Style="{StaticResource IconButton}"
                                                Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding HuggingFaceUrl}"
                                                ToolTip="Open model card on HuggingFace"
                                                Padding="6,4" Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource BlueBrush}"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="Read more" FontSize="11"
                                                           Foreground="{StaticResource BlueBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- Load button (shown when installed) -->
                                        <Button Content="Load"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DataContext.LoadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding LocalPath}"
                                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolVis}}"
                                                Padding="14,8"/>
                                        <!-- Download button (shown when NOT installed) -->
                                        <Button Content="Download"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.DownloadSearchResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.IsDownloading, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InvertBool}}"
                                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"
                                                Padding="14,8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- WHERE TO GET MODELS TAB                                -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsChecked, ElementName=SourcesTab, Converter={StaticResource BoolVis}}"
                        Margin="0,16,0,0">
                <TextBlock Text="Where to Get GGUF Models" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap">
                    GGUF is the standard format for local LLM inference. Download .gguf files and load them with the "Load GGUF File" button.
                    Q4_K_M quantization offers the best balance of quality and size.
                </TextBlock>

                <!-- Model Sources -->
                <ItemsControl ItemsSource="{Binding ModelSources}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Url}"
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,0,0,6" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Style="{StaticResource Card}" x:Name="CardBorder">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{StaticResource Surface1Brush}" CornerRadius="8"
                                                        Width="40" Height="40" Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="18" Foreground="{StaticResource BlueBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}" FontSize="14"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{StaticResource Subtext0Brush}"
                                                               FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="&#xE8A7;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{StaticResource Overlay0Brush}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background"
                                                        Value="{StaticResource Surface1Brush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Tips Section -->
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Tips for Choosing Models" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,0,0,10"/>

                        <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,6">
                            <Bold Foreground="{StaticResource TealBrush}">Quantization:</Bold>
                            Q4_K_M = best quality/size ratio. Q8_0 = near-original quality. Q2_K = smallest but lower quality.
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,6">
                            <Bold Foreground="{StaticResource TealBrush}">VRAM Guide:</Bold>
                            4GB VRAM = 1-3B models, 8GB = 7B models, 12GB = 13B models, 16GB+ = 14-32B models, 24GB+ = 70B models (Q4).
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,6">
                            <Bold Foreground="{StaticResource TealBrush}">For Coding:</Bold>
                            Qwen2.5 Coder, DeepSeek Coder, and StarCoder2 are the best coding-specialized models.
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="12"
                                   TextWrapping="Wrap">
                            <Bold Foreground="{StaticResource TealBrush}">Portability:</Bold>
                            Place a "portable.txt" file next to CluadeX.exe to store all data alongside the app (USB-friendly).
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
