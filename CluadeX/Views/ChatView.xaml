<UserControl x:Class="CluadeX.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CluadeX.Converters"
             xmlns:models="clr-namespace:CluadeX.Models"
             xmlns:helpers="clr-namespace:CluadeX.Helpers"
             xmlns:vm="clr-namespace:CluadeX.ViewModels">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:RoleToBrushConverter x:Key="RoleBrush"/>
        <conv:RoleToBackgroundConverter x:Key="RoleBg"/>
        <conv:RoleToLabelConverter x:Key="RoleLabel"/>
        <conv:RoleToAlignmentConverter x:Key="RoleAlign"/>
        <conv:RoleToMarginConverter x:Key="RoleMargin"/>
        <conv:RoleToCornerRadiusConverter x:Key="RoleCorner"/>
        <conv:InverseBoolConverter x:Key="InvertBool"/>
        <conv:BoolToStringConverter x:Key="BoolStr"/>
        <conv:ContextUsageBrushConverter x:Key="CtxBrush"/>
        <conv:ContextLedGateConverter x:Key="CtxLedGate"/>

        <!-- ═══ Reusable Pulse Animation Style ═══ -->
        <Style x:Key="PulseDot" TargetType="Ellipse">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PulseAnim">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                    From="0.3" To="1.0" Duration="0:0:0.4" AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PulseAnim"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PROJECT BAR -->
        <Border Grid.Row="0" Background="{StaticResource Surface0Brush}"
                Padding="12,8"
                Visibility="{Binding HasProject, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                           Foreground="{StaticResource TealBrush}"
                           FontSize="14" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1" Text="{Binding WorkingDirectory}"
                           Foreground="{StaticResource Subtext0Brush}"
                           FontSize="12" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontFamily="{StaticResource MonoFont}"/>

                <!-- Git Branch Badge -->
                <Border Grid.Column="2" CornerRadius="4" Padding="6,2" Margin="8,0"
                        Background="{StaticResource Surface1Brush}"
                        Visibility="{Binding GitBranch, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding GitBranch}"
                                   Foreground="{StaticResource GreenBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Agent + Thinking Toggles -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Agent" Margin="8,0,4,0"
                              IsChecked="{Binding AgenticMode}"
                              Foreground="{StaticResource Subtext0Brush}"
                              FontSize="10" VerticalAlignment="Center"
                              ToolTip="Enable agentic mode (file access, commands, Git)"/>
                    <CheckBox Content="Thinking" Margin="4,0"
                              IsChecked="{Binding ShowThinking}"
                              Foreground="{StaticResource Subtext0Brush}"
                              FontSize="10" VerticalAlignment="Center"
                              ToolTip="Show AI thinking/reasoning steps in real-time"/>
                </StackPanel>

                <Button Grid.Column="4" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource IconButton}"
                        Command="{Binding CloseFolderCommand}"
                        ToolTip="Close project folder"
                        FontSize="11" Padding="6,4"/>
            </Grid>
        </Border>

        <!-- ═══ IN-CHAT SEARCH BAR (Ctrl+F) ═══ -->
        <Border Grid.Row="1" VerticalAlignment="Top" Panel.ZIndex="10"
                Background="{StaticResource MantleBrush}"
                Padding="12,6" BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource Surface0Brush}"
                Visibility="{Binding IsChatSearchVisible, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{StaticResource Overlay0Brush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="ChatSearchBox"
                         Text="{Binding ChatSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource GlowTextBox}"
                         FontSize="13" FontFamily="{StaticResource MonoFont}"
                         Padding="8,4" Height="28"/>
                <TextBlock Grid.Column="2"
                           Foreground="{StaticResource Overlay0Brush}"
                           FontSize="11" FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center" Margin="8,0">
                    <TextBlock.Text>
                        <Binding Path="SearchMatchCount" StringFormat="{}{0} matches"/>
                    </TextBlock.Text>
                </TextBlock>
                <Button Grid.Column="3" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource IconButton}" FontSize="10" Padding="4,4"
                        Command="{Binding CloseChatSearchCommand}"
                        ToolTip="Close search (Esc)"/>
            </Grid>
        </Border>

        <!-- ═══ CHAT MESSAGES AREA (Virtualized) ═══ -->
        <Border Grid.Row="1" Background="{StaticResource BaseBrush}">
                <ListBox x:Name="ChatList" ItemsSource="{Binding Messages}" Margin="8,0"
                         Background="Transparent" BorderThickness="0"
                         Padding="0,8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         VirtualizingStackPanel.ScrollUnit="Pixel"
                         SelectionMode="Single"
                         HorizontalContentAlignment="Stretch">
                    <!-- Use slim scrollbar style for the ListBox's internal ScrollViewer -->
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer Style="{StaticResource SlimScrollViewer}"
                                              Focusable="False"
                                              CanContentScroll="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1,0,1"
                                  MouseEnter="MessageBubble_MouseEnter"
                                  MouseLeave="MessageBubble_MouseLeave">

                                <!-- ═══ Thinking Block (collapsible) ═══ -->
                                <Border HorizontalAlignment="Left"
                                        Margin="12,2,200,2"
                                        Background="#18CBA6F7"
                                        CornerRadius="8" Padding="10,4"
                                        Visibility="{Binding HasThinking, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Cursor="Hand"
                                                    MouseLeftButtonDown="ThinkingHeader_Click">
                                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="{StaticResource MauveBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Thinking" FontSize="11" FontStyle="Italic"
                                                       Foreground="{StaticResource MauveBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                       Foreground="{StaticResource Overlay0Brush}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE76C;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsThinkingExpanded}" Value="True">
                                                                <Setter Property="Text" Value="&#xE76B;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border MaxHeight="200" Margin="0,4,0,0"
                                                Visibility="{Binding IsThinkingExpanded, Converter={StaticResource BoolVis}}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <TextBlock Text="{Binding ThinkingContent}"
                                                           Foreground="{StaticResource Overlay0Brush}"
                                                           FontSize="11" FontStyle="Italic"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Permission Request: inline Yes/No prompt ═══ -->
                                <Border HorizontalAlignment="Left"
                                        Margin="12,4,100,4"
                                        Background="#20F9E2AF"
                                        BorderBrush="{StaticResource YellowBrush}"
                                        BorderThickness="2,0,0,0"
                                        CornerRadius="0,8,8,0"
                                        Padding="12,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.PermissionRequest}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{StaticResource YellowBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="13" FontFamily="{StaticResource MainFont}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="22,0,0,0">
                                            <Button Content="Allow" Padding="16,4" Margin="0,0,8,0"
                                                    Style="{StaticResource PrimaryButton}"
                                                    FontSize="12"
                                                    Click="PermissionAllow_Click"/>
                                            <Button Content="Deny" Padding="16,4"
                                                    Style="{StaticResource SecondaryButton}"
                                                    FontSize="12"
                                                    Click="PermissionDeny_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ AgentStatus: inline tool indicator ═══ -->
                                <Border HorizontalAlignment="Left"
                                        Margin="12,2,200,2"
                                        Background="{StaticResource Surface0Brush}"
                                        CornerRadius="8"
                                        Padding="10,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.AgentStatus}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="9" Height="9" Margin="0,0,10,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource Overlay0Brush}"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource MauveBrush}"/>
                                                            <Setter Property="Opacity" Value="1"/>
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="StatusPulse">
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                            From="0.4" To="1.0" Duration="0:0:0.5"
                                                                            AutoReverse="True"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="StatusPulse"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <!-- Status text + elapsed time -->
                                        <TextBlock Text="{Binding Content}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="13"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ToolElapsedTime}"
                                                   Foreground="{StaticResource Overlay0Brush}"
                                                   FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Visibility="{Binding ToolElapsedTime, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}"/>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Normal chat bubble ═══ -->
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.AgentStatus}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ⎿ Gutter line for ToolAction (Claude Code-style vertical connector) -->
                                    <Border Grid.Column="0" Width="2" Margin="14,0,0,0"
                                            Background="{StaticResource Overlay0Brush}"
                                            CornerRadius="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                <Border Grid.Column="1"
                                        HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}"
                                        Margin="{Binding Role, Converter={StaticResource RoleMargin}}"
                                        Background="{Binding Role, Converter={StaticResource RoleBg}}"
                                        CornerRadius="{Binding Role, Converter={StaticResource RoleCorner}}"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Role label + Tool Badge + Success/Fail + Hover Actions -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.User}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <TextBlock Text="{Binding Role, Converter={StaticResource RoleLabel}}"
                                                           Foreground="{Binding Role, Converter={StaticResource RoleBrush}}"
                                                           FontWeight="SemiBold" FontSize="11"
                                                           FontFamily="{StaticResource MainFont}"/>

                                                <!-- Tool Name Badge -->
                                                <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                        Background="{StaticResource Surface1Brush}"
                                                        Visibility="{Binding ToolName, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                                    <TextBlock Text="{Binding ToolName}"
                                                               Foreground="{StaticResource TealBrush}"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"/>
                                                </Border>

                                                <!-- Collapsed group count badge -->
                                                <Border CornerRadius="8" Padding="5,1" Margin="4,0,0,0"
                                                        Background="{StaticResource MauveBrush}"
                                                        Visibility="{Binding IsCollapsedGroup, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                                    <TextBlock Text="{Binding CollapsedCount}"
                                                               Foreground="{StaticResource BaseBrush}"
                                                               FontSize="9" FontWeight="Bold"
                                                               FontFamily="{StaticResource MonoFont}"/>
                                                </Border>

                                                <!-- Success/Fail indicator -->
                                                <TextBlock Text="&#x2713;" Foreground="{StaticResource GreenBrush}"
                                                           FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}"/>
                                                                        <Condition Binding="{Binding ToolSuccess}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text="&#x2717;" Foreground="{StaticResource RedBrush}"
                                                           FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}"/>
                                                                        <Condition Binding="{Binding ToolSuccess}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Interrupted indicator -->
                                                <Border CornerRadius="4" Padding="4,1" Margin="6,0,0,0"
                                                        Background="#30F38BA8"
                                                        Visibility="{Binding IsInterrupted, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                                    <TextBlock Text="interrupted" FontSize="9"
                                                               Foreground="{StaticResource RedBrush}"
                                                               FontFamily="{StaticResource MonoFont}"/>
                                                </Border>

                                                <!-- Retry countdown -->
                                                <Border CornerRadius="4" Padding="4,1" Margin="6,0,0,0"
                                                        Background="#30F9E2AF"
                                                        Visibility="{Binding IsRetrying, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                                    <TextBlock Text="{Binding RetryCountdown}" FontSize="9"
                                                               Foreground="{StaticResource YellowBrush}"
                                                               FontFamily="{StaticResource MonoFont}"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- ═══ Hover Action Buttons (Copy + Retry) ═══ -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        Visibility="{Binding IsHovered, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                                <!-- Copy message -->
                                                <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                        Style="{StaticResource IconButton}"
                                                        FontSize="10" Padding="4,2" Margin="2,0"
                                                        ToolTip="Copy message"
                                                        Click="CopyMessage_Click"
                                                        Tag="{Binding Content}"/>
                                                <!-- Retry (only for error messages) -->
                                                <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                                        Style="{StaticResource IconButton}"
                                                        FontSize="10" Padding="4,2" Margin="2,0"
                                                        ToolTip="Retry"
                                                        Click="RetryMessage_Click"
                                                        Visibility="{Binding HasError, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Row 1: Tool Arguments (truncated, structured) -->
                                        <Border Grid.Row="1" Margin="0,4,0,0"
                                                Background="{StaticResource CrustBrush}"
                                                CornerRadius="4" Padding="8,5"
                                                MaxHeight="120">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}"/>
                                                                <Condition Binding="{Binding ToolArguments, Converter={StaticResource BoolVis}}" Value="Visible"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <TextBlock Text="{Binding ToolArguments}"
                                                           Foreground="{StaticResource Subtext0Brush}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           MaxHeight="100"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </ScrollViewer>
                                        </Border>

                                        <!-- Row 2: Message Content with Markdown -->
                                        <StackPanel Grid.Row="2" Margin="0,3,0,0"
                                                    helpers:MarkdownHelper.Markdown="{Binding Content}"/>

                                        <!-- Row 3: Typing Indicator -->
                                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsStreaming}" Value="True"/>
                                                                <Condition Binding="{Binding Content}" Value=""/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource MauveBrush}" Margin="0,0,4,0"
                                                     Style="{StaticResource PulseDot}"/>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource MauveBrush}" Margin="0,0,4,0"
                                                     Style="{StaticResource PulseDot}"/>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource MauveBrush}"
                                                     Style="{StaticResource PulseDot}"/>
                                            <TextBlock Text="  Thinking..."
                                                       Foreground="{StaticResource Subtext0Brush}"
                                                       FontSize="11" FontStyle="Italic"
                                                       FontFamily="{StaticResource MainFont}"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>

                                        <!-- Row 4: Tool Output (collapsible) -->
                                        <Expander Grid.Row="4" Margin="0,6,0,0"
                                                  IsExpanded="{Binding IsExpanded}">
                                            <Expander.Header>
                                                <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="11">
                                                    <Run Text="Show output"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding ToolOutputLines, Mode=OneWay}"/>
                                                    <Run Text=" lines)"/>
                                                </TextBlock>
                                            </Expander.Header>
                                            <Border Background="{StaticResource Surface0Brush}"
                                                    CornerRadius="6" Padding="10,8" Margin="0,4,0,0"
                                                    MaxHeight="300">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Auto">
                                                    <TextBlock Text="{Binding ToolOutput}"
                                                               Foreground="{StaticResource Subtext0Brush}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="11" TextWrapping="Wrap"/>
                                                </ScrollViewer>
                                            </Border>
                                            <Expander.Style>
                                                <Style TargetType="Expander" BasedOn="{StaticResource ToolExpander}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Expander.Style>
                                        </Expander>

                                        <!-- Row 5: Error bar with retry hint -->
                                        <Border Grid.Row="5" Margin="0,4,0,0" Padding="6,3"
                                                Background="#20F38BA8" CornerRadius="4"
                                                Visibility="{Binding HasError, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                            <TextBlock FontSize="10" Foreground="{StaticResource RedBrush}"
                                                       FontFamily="{StaticResource MainFont}">
                                                <Run Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                                <Run Text=" An error occurred. Hover for retry button."/>
                                            </TextBlock>
                                        </Border>

                                        <!-- Row 6: Footer — streaming dots + timestamp -->
                                        <StackPanel Grid.Row="6" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <!-- Compact streaming indicator -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,6,0"
                                                        Visibility="{Binding IsStreaming, Converter={StaticResource BoolVis}}">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource MauveBrush}" Margin="1,0"
                                                         Style="{StaticResource PulseDot}"/>
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource MauveBrush}" Margin="1,0"
                                                         Style="{StaticResource PulseDot}"/>
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource MauveBrush}" Margin="1,0"
                                                         Style="{StaticResource PulseDot}"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                       Foreground="{StaticResource Overlay0Brush}"
                                                       FontSize="9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                </Grid><!-- close gutter+bubble Grid -->
                            </Grid><!-- close message wrapper Grid -->
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
        </Border>

        <!-- ═══ EMPTY STATE with Suggested Prompts ═══ -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Messages.Count, Converter={StaticResource BoolVis}, ConverterParameter=Invert, FallbackValue=Visible}">
            <TextBlock Text="&#x2728;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="CluadeX AI Coding Assistant"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="24" FontWeight="Bold"
                       FontFamily="{StaticResource MainFont}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ask me to write, debug, or explain any code."
                       Foreground="{StaticResource Subtext0Brush}"
                       FontSize="14" HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

            <!-- Suggested Prompts -->
            <WrapPanel HorizontalAlignment="Center" Margin="0,24,0,0" MaxWidth="600">
                <Button Style="{StaticResource SecondaryButton}" Margin="4" Padding="12,8"
                        Click="SuggestedPrompt_Click"
                        Tag="Explain this codebase's architecture and key patterns">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource MauveBrush}"/>
                        <TextBlock Text="Explain codebase" FontSize="12" FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Margin="4" Padding="12,8"
                        Click="SuggestedPrompt_Click"
                        Tag="Find and fix bugs in this project">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource RedBrush}"/>
                        <TextBlock Text="Find bugs" FontSize="12" FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Margin="4" Padding="12,8"
                        Click="SuggestedPrompt_Click"
                        Tag="Write unit tests for the most critical code paths">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource GreenBrush}"/>
                        <TextBlock Text="Write tests" FontSize="12" FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Margin="4" Padding="12,8"
                        Click="SuggestedPrompt_Click"
                        Tag="Review recent changes and suggest improvements">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BE;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TealBrush}"/>
                        <TextBlock Text="Code review" FontSize="12" FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <Button Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenFolderCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0" Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                               FontSize="16" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Open Project Folder" FontFamily="{StaticResource MainFont}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Text="Open a folder to enable agent mode (file access, editing, commands)"
                       Foreground="{StaticResource Overlay0Brush}"
                       FontSize="11" HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="{StaticResource MantleBrush}"
                Padding="20,12" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Surface0Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <TextBox x:Name="InputBox"
                             Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource GlowTextBox}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="14"
                             MaxHeight="150"
                             VerticalScrollBarVisibility="Auto"
                             IsEnabled="{Binding IsGenerating, Converter={StaticResource InvertBool}}"/>

                    <TextBlock Text="Type a message... (Enter to send, Shift+Enter for new line)"
                               FontFamily="{StaticResource MainFont}"
                               FontSize="13"
                               Foreground="{StaticResource Overlay0Brush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding UserInput, Converter={StaticResource BoolVis}, ConverterParameter=Invert, FallbackValue=Visible}"/>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="&#xE838;" Style="{StaticResource IconButton}"
                            Command="{Binding OpenFolderCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            ToolTip="Open project folder"
                            Margin="0,0,4,0"/>

                    <Button Content="&#xE725;" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SendMessageCommand}"
                            FontFamily="Segoe MDL2 Assets" FontSize="16"
                            Padding="14,10" Margin="0,0,4,0"
                            ToolTip="Send message (Enter)"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"/>

                    <Button Content="&#xE71A;" Style="{StaticResource DangerButton}"
                            Command="{Binding StopGenerationCommand}"
                            FontFamily="Segoe MDL2 Assets" FontSize="16"
                            Padding="14,10" Margin="0,0,4,0"
                            ToolTip="Stop generation"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolVis}}"/>

                    <Button Content="&#xE74D;" Style="{StaticResource IconButton}"
                            Command="{Binding ClearChatCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            ToolTip="Clear chat"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEXT WARNING BAR with action buttons -->
        <Border Grid.Row="3" Padding="10,6"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Surface0Brush}"
                Visibility="{Binding ShowContextWarning, Converter={StaticResource BoolVis}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.1"/>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource YellowBrush}"/>
                    <ProgressBar Value="{Binding ContextUsagePercent}" Maximum="100"
                                 Width="120" Height="8"
                                 Style="{StaticResource ContextProgressBar}"
                                 Foreground="{Binding ContextUsagePercent, Converter={StaticResource CtxBrush}}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ContextUsageText}"
                               Foreground="{StaticResource YellowBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding ContextWarningText}"
                           Foreground="{StaticResource YellowBrush}"
                           FontSize="11" FontFamily="{StaticResource MainFont}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Compact button -->
                <Button Grid.Column="2" Padding="8,3" Margin="4,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CompactCommand}"
                        ToolTip="Compress conversation to free up context">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Compact" FontFamily="{StaticResource MainFont}"
                                   FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- New Chat button -->
                <Button Grid.Column="3" Padding="10,4" Margin="4,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewSessionCommand}"
                        ToolTip="Start a new chat to reset context">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="New Chat" FontFamily="{StaticResource MainFont}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- MODEL SELECTOR + STATUS BAR -->
        <Border Grid.Row="4" Background="{StaticResource CrustBrush}" Padding="8,4"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Surface0Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Model Selector -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="{StaticResource MauveBrush}"
                               VerticalAlignment="Center" Margin="4,0,6,0"/>
                    <ComboBox ItemsSource="{Binding LocalModels}"
                              SelectedItem="{Binding SelectedLocalModel}"
                              Style="{StaticResource ModernComboBox}"
                              Width="220" FontSize="11"
                              ToolTip="Select a local model to load">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontSize="11"
                                               FontFamily="{StaticResource MainFont}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding QuantizationType}" FontSize="9"
                                               Foreground="{StaticResource MauveBrush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding FileSizeDisplay}" FontSize="9"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource IconButton}"
                            Command="{Binding RefreshModelsCommand}"
                            ToolTip="Refresh model list"
                            FontSize="10" Padding="4,4" Margin="2,0,0,0"/>
                    <TextBlock Text="Loading..."
                               Foreground="{StaticResource YellowBrush}"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding IsLoadingModel, Converter={StaticResource BoolVis}}"/>
                </StackPanel>

                <!-- Status Text + Generating Spinner -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource Subtext0Brush}"
                               FontSize="11" VerticalAlignment="Center"
                               FontFamily="{StaticResource MainFont}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="{StaticResource MauveBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="StatusSpin">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                            From="0" To="360" Duration="0:0:1.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="StatusSpin"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Generating..."
                                   Foreground="{StaticResource MauveBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="GenPulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                            From="1.0" To="0.4" Duration="0:0:0.8"
                                                            AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="GenPulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- LED Context Bar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0"
                                ToolTip="Context Memory — AI quality degrades as this fills up">
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.15"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=0}" Value="True"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.9"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                        </Border>
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.15"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=25}" Value="True"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource TealColor}" Opacity="0.9"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                        </Border>
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.15"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=50}" Value="True"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.9"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                        </Border>
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource PeachColor}" Opacity="0.15"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=75}" Value="True"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource PeachColor}" Opacity="0.9"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                        </Border>
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource RedColor}" Opacity="0.15"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=90}" Value="True"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource RedColor}" Opacity="0.9"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                        </Border>
                    </StackPanel>
                    <Border CornerRadius="3" Padding="4,1" VerticalAlignment="Center"
                            Background="{Binding ContextUsagePercent, Converter={StaticResource CtxBrush}}"
                            Opacity="0.8" Margin="0,0,4,0">
                        <TextBlock Text="{Binding ContextLevelLabel}"
                                   FontSize="8" FontWeight="ExtraBold"
                                   Foreground="{StaticResource BaseBrush}"
                                   FontFamily="{StaticResource MonoFont}"/>
                    </Border>
                    <TextBlock Foreground="{StaticResource Overlay0Brush}"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="ContextUsagePercent" StringFormat="{}{0:F0}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Per-Turn Stats -->
                <TextBlock Grid.Column="3" Text="{Binding LastTurnStats}"
                           Foreground="{StaticResource Overlay0Brush}"
                           FontSize="9" FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center" Margin="6,0"
                           ToolTip="Last turn: tokens · time · speed"/>

                <!-- API Cost -->
                <TextBlock Grid.Column="3" Text="{Binding CostText}"
                           Foreground="{StaticResource MauveBrush}"
                           FontSize="9" FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center" Margin="6,0"
                           ToolTip="Session API cost (USD)"/>

                <!-- Review + Auto-Execute -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding ReviewCodeCommand}"
                            ToolTip="Review code changes"
                            FontSize="10" Padding="4,3" Margin="0,0,4,0"
                            Visibility="{Binding HasProject, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#xE7BE;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <CheckBox Content="Auto" IsChecked="{Binding AutoExecute}"
                              Foreground="{StaticResource Subtext0Brush}"
                              FontSize="9" VerticalAlignment="Center"
                              ToolTip="Automatically run code blocks and fix errors"/>
                    <CheckBox IsChecked="{Binding ExtendedThinkingEnabled}"
                              Foreground="{StaticResource MauveBrush}"
                              FontSize="9" VerticalAlignment="Center" Margin="8,0,0,0"
                              ToolTip="Extended Thinking — enables deeper reasoning (Anthropic only)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Think" VerticalAlignment="Center"/>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <Button Grid.Column="5" Style="{StaticResource IconButton}"
                        Command="{Binding NewSessionCommand}"
                        ToolTip="New Chat"
                        FontSize="12" Padding="6,4" Margin="4,0">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
