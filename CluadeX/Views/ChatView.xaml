<UserControl x:Class="CluadeX.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CluadeX.Converters"
             xmlns:models="clr-namespace:CluadeX.Models"
             xmlns:helpers="clr-namespace:CluadeX.Helpers"
             xmlns:vm="clr-namespace:CluadeX.ViewModels">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:RoleToBrushConverter x:Key="RoleBrush"/>
        <conv:RoleToBackgroundConverter x:Key="RoleBg"/>
        <conv:RoleToLabelConverter x:Key="RoleLabel"/>
        <conv:RoleToAlignmentConverter x:Key="RoleAlign"/>
        <conv:RoleToMarginConverter x:Key="RoleMargin"/>
        <conv:RoleToCornerRadiusConverter x:Key="RoleCorner"/>
        <conv:InverseBoolConverter x:Key="InvertBool"/>
        <conv:BoolToStringConverter x:Key="BoolStr"/>
        <conv:ContextUsageBrushConverter x:Key="CtxBrush"/>
        <conv:ContextLedGateConverter x:Key="CtxLedGate"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PROJECT BAR -->
        <Border Grid.Row="0" Background="{StaticResource Surface0Brush}"
                Padding="12,8"
                Visibility="{Binding HasProject, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                           Foreground="{StaticResource TealBrush}"
                           FontSize="14" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1" Text="{Binding WorkingDirectory}"
                           Foreground="{StaticResource Subtext0Brush}"
                           FontSize="12" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontFamily="{StaticResource MonoFont}"/>

                <!-- Git Branch Badge -->
                <Border Grid.Column="2" CornerRadius="4" Padding="6,2" Margin="8,0"
                        Background="{StaticResource Surface1Brush}"
                        Visibility="{Binding GitBranch, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding GitBranch}"
                                   Foreground="{StaticResource GreenBrush}"
                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Agent + Thinking Toggles -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Agent" Margin="8,0,4,0"
                              IsChecked="{Binding AgenticMode}"
                              Foreground="{StaticResource Subtext0Brush}"
                              FontSize="10" VerticalAlignment="Center"
                              ToolTip="Enable agentic mode (file access, commands, Git)"/>
                    <CheckBox Content="Thinking" Margin="4,0"
                              IsChecked="{Binding ShowThinking}"
                              Foreground="{StaticResource Subtext0Brush}"
                              FontSize="10" VerticalAlignment="Center"
                              ToolTip="Show AI thinking/reasoning steps in real-time"/>
                </StackPanel>

                <Button Grid.Column="4" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource IconButton}"
                        Command="{Binding CloseFolderCommand}"
                        ToolTip="Close project folder"
                        FontSize="11" Padding="6,4"/>
            </Grid>
        </Border>

        <!-- CHAT MESSAGES AREA -->
        <Border Grid.Row="1" Background="{StaticResource BaseBrush}">
            <ScrollViewer x:Name="ChatScroller"
                          Style="{StaticResource SlimScrollViewer}"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,8">
                <ItemsControl ItemsSource="{Binding Messages}" Margin="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Chat bubble wrapper (full width Grid so HorizontalAlignment works) -->
                            <Grid>
                                <Border HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}"
                                        Margin="{Binding Role, Converter={StaticResource RoleMargin}}"
                                        Background="{Binding Role, Converter={StaticResource RoleBg}}"
                                        CornerRadius="{Binding Role, Converter={StaticResource RoleCorner}}"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Role label (hidden for User) -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.User}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="{Binding Role, Converter={StaticResource RoleLabel}}"
                                                       Foreground="{Binding Role, Converter={StaticResource RoleBrush}}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       FontFamily="{StaticResource MainFont}"/>

                                            <!-- Tool Name Badge -->
                                            <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                    Background="{StaticResource Surface1Brush}"
                                                    Visibility="{Binding ToolName, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
                                                <TextBlock Text="{Binding ToolName}"
                                                           Foreground="{StaticResource TealBrush}"
                                                           FontSize="10" FontFamily="{StaticResource MonoFont}"/>
                                            </Border>

                                            <!-- Success/Fail indicator -->
                                            <TextBlock Text="&#x2713;" Foreground="{StaticResource GreenBrush}"
                                                       FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}"/>
                                                                    <Condition Binding="{Binding ToolSuccess}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Text="&#x2717;" Foreground="{StaticResource RedBrush}"
                                                       FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}"/>
                                                                    <Condition Binding="{Binding ToolSuccess}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Tool Arguments (shown for ToolAction messages with arguments) -->
                                        <Border Grid.Row="1" Margin="0,4,0,0"
                                                Background="{StaticResource CrustBrush}"
                                                CornerRadius="4" Padding="8,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}"/>
                                                                <Condition Binding="{Binding ToolArguments, Converter={StaticResource BoolVis}}" Value="Visible"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding ToolArguments}"
                                                       Foreground="{StaticResource Subtext0Brush}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </Border>

                                        <!-- Message Content with Markdown Rendering -->
                                        <StackPanel Grid.Row="1" Margin="0,3,0,0"
                                                    helpers:MarkdownHelper.Markdown="{Binding Content}"/>

                                        <!-- Typing Indicator (shown ONLY when streaming AND content is still empty) -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsStreaming}" Value="True"/>
                                                                <Condition Binding="{Binding Content}" Value=""/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource MauveBrush}" Margin="0,0,4,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard x:Name="ThinkDot1">
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                From="0.3" To="1.0" Duration="0:0:0.4"
                                                                                AutoReverse="True" BeginTime="0:0:0"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="ThinkDot1"/>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource MauveBrush}" Margin="0,0,4,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard x:Name="ThinkDot2">
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                From="0.3" To="1.0" Duration="0:0:0.4"
                                                                                AutoReverse="True" BeginTime="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="ThinkDot2"/>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource MauveBrush}">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard x:Name="ThinkDot3">
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                From="0.3" To="1.0" Duration="0:0:0.4"
                                                                                AutoReverse="True" BeginTime="0:0:0.3"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="ThinkDot3"/>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="  Thinking..."
                                                       Foreground="{StaticResource Subtext0Brush}"
                                                       FontSize="11" FontStyle="Italic"
                                                       FontFamily="{StaticResource MainFont}"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>

                                        <!-- Tool Output (collapsible) -->
                                        <Expander Grid.Row="3" Margin="0,6,0,0"
                                                  IsExpanded="{Binding IsExpanded}">
                                            <Expander.Header>
                                                <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="11">
                                                    <Run Text="Show output"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding ToolOutputLines, Mode=OneWay}"/>
                                                    <Run Text=" lines)"/>
                                                </TextBlock>
                                            </Expander.Header>
                                            <Border Background="{StaticResource Surface0Brush}"
                                                    CornerRadius="6" Padding="10,8" Margin="0,4,0,0"
                                                    MaxHeight="300">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Auto">
                                                    <TextBlock Text="{Binding ToolOutput}"
                                                               Foreground="{StaticResource Subtext0Brush}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="11" TextWrapping="Wrap"/>
                                                </ScrollViewer>
                                            </Border>
                                            <Expander.Style>
                                                <Style TargetType="Expander" BasedOn="{StaticResource ToolExpander}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="{x:Static models:MessageRole.ToolAction}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Expander.Style>
                                        </Expander>

                                        <!-- Footer: timestamp + streaming dots -->
                                        <StackPanel Grid.Row="4" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <!-- Streaming dots (inline) -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,6,0"
                                                        Visibility="{Binding IsStreaming, Converter={StaticResource BoolVis}}">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource MauveBrush}" Margin="1,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard x:Name="Dot1Pulse">
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                    From="0.2" To="1.0" Duration="0:0:0.5"
                                                                                    AutoReverse="True" BeginTime="0:0:0"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <StopStoryboard BeginStoryboardName="Dot1Pulse"/>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource MauveBrush}" Margin="1,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard x:Name="Dot2Pulse">
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                    From="0.2" To="1.0" Duration="0:0:0.5"
                                                                                    AutoReverse="True" BeginTime="0:0:0.2"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <StopStoryboard BeginStoryboardName="Dot2Pulse"/>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource MauveBrush}" Margin="1,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard x:Name="Dot3Pulse">
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                    From="0.2" To="1.0" Duration="0:0:0.5"
                                                                                    AutoReverse="True" BeginTime="0:0:0.4"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <StopStoryboard BeginStoryboardName="Dot3Pulse"/>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                       Foreground="{StaticResource Overlay0Brush}"
                                                       FontSize="9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- EMPTY STATE -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Messages.Count, Converter={StaticResource BoolVis}, ConverterParameter=Invert, FallbackValue=Visible}">
            <TextBlock Text="&#x2728;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="CluadeX AI Coding Assistant"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="24" FontWeight="Bold"
                       FontFamily="{StaticResource MainFont}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ask me to write, debug, or explain any code."
                       Foreground="{StaticResource Subtext0Brush}"
                       FontSize="14" HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
            <TextBlock Text="Select a model below or download one from the Models tab."
                       Foreground="{StaticResource Overlay0Brush}"
                       FontSize="12" HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

            <Button Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenFolderCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0" Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                               FontSize="16" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Open Project Folder" FontFamily="{StaticResource MainFont}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Text="Open a folder to enable agent mode (file access, editing, commands)"
                       Foreground="{StaticResource Overlay0Brush}"
                       FontSize="11" HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="{StaticResource MantleBrush}"
                Padding="20,12" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Surface0Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input box with placeholder overlay -->
                <Grid>
                    <TextBox x:Name="InputBox"
                             Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource GlowTextBox}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="14"
                             MaxHeight="150"
                             VerticalScrollBarVisibility="Auto"
                             IsEnabled="{Binding IsGenerating, Converter={StaticResource InvertBool}}"/>

                    <!-- Placeholder text -->
                    <TextBlock Text="Type a message... (Enter to send, Shift+Enter for new line)"
                               FontFamily="{StaticResource MainFont}"
                               FontSize="13"
                               Foreground="{StaticResource Overlay0Brush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding UserInput, Converter={StaticResource BoolVis}, ConverterParameter=Invert, FallbackValue=Visible}"/>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                    <!-- Open Folder Button -->
                    <Button Content="&#xE838;" Style="{StaticResource IconButton}"
                            Command="{Binding OpenFolderCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            ToolTip="Open project folder"
                            Margin="0,0,4,0"/>

                    <!-- Send Button -->
                    <Button Content="&#xE725;" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SendMessageCommand}"
                            FontFamily="Segoe MDL2 Assets" FontSize="16"
                            Padding="14,10" Margin="0,0,4,0"
                            ToolTip="Send message (Enter)"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"/>

                    <!-- Stop Button -->
                    <Button Content="&#xE71A;" Style="{StaticResource DangerButton}"
                            Command="{Binding StopGenerationCommand}"
                            FontFamily="Segoe MDL2 Assets" FontSize="16"
                            Padding="14,10" Margin="0,0,4,0"
                            ToolTip="Stop generation"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolVis}}"/>

                    <!-- Clear Button -->
                    <Button Content="&#xE74D;" Style="{StaticResource IconButton}"
                            Command="{Binding ClearChatCommand}"
                            FontFamily="Segoe MDL2 Assets"
                            ToolTip="Clear chat"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEXT WARNING BAR (slides in when context is getting full) -->
        <Border Grid.Row="3" Padding="10,6"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Surface0Brush}"
                Visibility="{Binding ShowContextWarning, Converter={StaticResource BoolVis}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.1"/>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Context bar (prominent) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource YellowBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowContextWarning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="WarnPulse">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                        From="1.0" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="WarnPulse"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ProgressBar Value="{Binding ContextUsagePercent}" Maximum="100"
                                 Width="120" Height="8"
                                 Style="{StaticResource ContextProgressBar}"
                                 Foreground="{Binding ContextUsagePercent, Converter={StaticResource CtxBrush}}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ContextUsageText}"
                               Foreground="{StaticResource YellowBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Warning text -->
                <TextBlock Grid.Column="1" Text="{Binding ContextWarningText}"
                           Foreground="{StaticResource YellowBrush}"
                           FontSize="11" FontFamily="{StaticResource MainFont}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>

                <!-- New Chat button -->
                <Button Grid.Column="2" Padding="10,4" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewSessionCommand}"
                        ToolTip="Start a new chat to reset context">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="New Chat" FontFamily="{StaticResource MainFont}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- MODEL SELECTOR + STATUS BAR -->
        <Border Grid.Row="4" Background="{StaticResource CrustBrush}" Padding="8,4"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Surface0Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Model Selector -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="{StaticResource MauveBrush}"
                               VerticalAlignment="Center" Margin="4,0,6,0"/>
                    <ComboBox ItemsSource="{Binding LocalModels}"
                              SelectedItem="{Binding SelectedLocalModel}"
                              Style="{StaticResource ModernComboBox}"
                              Width="220" FontSize="11"
                              ToolTip="Select a local model to load">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontSize="11"
                                               FontFamily="{StaticResource MainFont}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding QuantizationType}" FontSize="9"
                                               Foreground="{StaticResource MauveBrush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding FileSizeDisplay}" FontSize="9"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- Refresh models button -->
                    <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource IconButton}"
                            Command="{Binding RefreshModelsCommand}"
                            ToolTip="Refresh model list"
                            FontSize="10" Padding="4,4" Margin="2,0,0,0"/>
                    <!-- Loading indicator -->
                    <TextBlock Text="Loading..."
                               Foreground="{StaticResource YellowBrush}"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding IsLoadingModel, Converter={StaticResource BoolVis}}"/>
                </StackPanel>

                <!-- Status Text + Generating Spinner -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource Subtext0Brush}"
                               FontSize="11" VerticalAlignment="Center"
                               FontFamily="{StaticResource MainFont}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                    <!-- Generating Spinner (animated) -->
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="{StaticResource MauveBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="StatusSpin">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                            From="0" To="360" Duration="0:0:1.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="StatusSpin"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Generating..."
                                   Foreground="{StaticResource MauveBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="GenPulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                            From="1.0" To="0.4" Duration="0:0:0.8"
                                                            AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="GenPulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- LED-Style Context Bar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0"
                            VerticalAlignment="Center">
                    <!-- 5-segment LED bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0"
                                ToolTip="Context Memory — AI quality degrades as this fills up">
                        <!-- Segment 1: 0-20% (Green) -->
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=0}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- Segment 2: 20-40% (Green) -->
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource GreenColor}" Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=20}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource TealColor}" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- Segment 3: 40-60% (Yellow) -->
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=40}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource YellowColor}" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- Segment 4: 60-80% (Peach) -->
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource PeachColor}" Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=60}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource PeachColor}" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- Segment 5: 80-100% (Red) -->
                        <Border Width="14" Height="8" CornerRadius="2" Margin="1,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource RedColor}" Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContextUsagePercent, Converter={StaticResource CtxLedGate}, ConverterParameter=80}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource RedColor}" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </StackPanel>

                    <!-- Level Label -->
                    <Border CornerRadius="3" Padding="4,1" VerticalAlignment="Center"
                            Background="{Binding ContextUsagePercent, Converter={StaticResource CtxBrush}}"
                            Opacity="0.8" Margin="0,0,4,0">
                        <TextBlock Text="{Binding ContextLevelLabel}"
                                   FontSize="8" FontWeight="ExtraBold"
                                   Foreground="{StaticResource BaseBrush}"
                                   FontFamily="{StaticResource MonoFont}"/>
                    </Border>

                    <!-- Percentage -->
                    <TextBlock Foreground="{StaticResource Overlay0Brush}"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="ContextUsagePercent" StringFormat="{}{0:F0}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Per-Turn Stats -->
                <TextBlock Grid.Column="3" Text="{Binding LastTurnStats}"
                           Foreground="{StaticResource Overlay0Brush}"
                           FontSize="9" FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center" Margin="6,0"
                           ToolTip="Last turn: tokens · time · speed"/>

                <!-- API Cost -->
                <TextBlock Grid.Column="3" Text="{Binding CostText}"
                           Foreground="{StaticResource MauveBrush}"
                           FontSize="9" FontFamily="{StaticResource MonoFont}"
                           VerticalAlignment="Center" Margin="6,0"
                           ToolTip="Session API cost (USD)"/>

                <!-- Review + Auto-Execute -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding ReviewCodeCommand}"
                            ToolTip="Review code changes"
                            FontSize="10" Padding="4,3" Margin="0,0,4,0"
                            Visibility="{Binding HasProject, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#xE7BE;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <CheckBox Content="Auto" IsChecked="{Binding AutoExecute}"
                              Foreground="{StaticResource Subtext0Brush}"
                              FontSize="9" VerticalAlignment="Center"
                              ToolTip="Automatically run code blocks and fix errors"/>
                    <CheckBox IsChecked="{Binding ExtendedThinkingEnabled}"
                              Foreground="{StaticResource MauveBrush}"
                              FontSize="9" VerticalAlignment="Center" Margin="8,0,0,0"
                              ToolTip="Extended Thinking — enables deeper reasoning with thinking blocks (Anthropic only)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Think" VerticalAlignment="Center"/>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <!-- New Chat quick button -->
                <Button Grid.Column="5" Style="{StaticResource IconButton}"
                        Command="{Binding NewSessionCommand}"
                        ToolTip="New Chat"
                        FontSize="12" Padding="6,4" Margin="4,0">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
