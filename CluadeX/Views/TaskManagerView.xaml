<UserControl x:Class="CluadeX.Views.TaskManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CluadeX.ViewModels">

    <UserControl.Resources>
        <!-- Status badge style -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Padding="24,16,24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Task Manager" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MainFont}" Margin="0,0,0,4"/>
                    <TextBlock Text="Run and monitor system commands"
                               Foreground="{StaticResource Subtext0Brush}" FontSize="13"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Clear Completed"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearCompletedCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════ TASK LIST ═══════ -->
        <Border Grid.Row="1" Margin="24,8,24,8" Background="{StaticResource Surface0Brush}"
                CornerRadius="8" Padding="0">
            <ListView ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding SelectedTask}"
                      Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListView.Resources>
                    <!-- Remove default selection highlight -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#45475A"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#313244"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#CDD6F4"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#CDD6F4"/>
                </ListView.Resources>

                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
                                <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>

                        <!-- ID Column -->
                        <GridViewColumn Header="ID" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}" Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="12"
                                               Margin="4,2"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Name Column -->
                        <GridViewColumn Header="Name" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource MainFont}" FontSize="12"
                                               TextTrimming="CharacterEllipsis" Margin="4,2"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Status Column -->
                        <GridViewColumn Header="Status" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                                <Setter Property="Padding" Value="8,3"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Background" Value="{StaticResource Overlay0Brush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="running">
                                                        <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="completed">
                                                        <Setter Property="Background" Value="{StaticResource BlueBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="failed">
                                                        <Setter Property="Background" Value="{StaticResource RedBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="stopped">
                                                        <Setter Property="Background" Value="{StaticResource YellowBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="11"
                                                   FontFamily="{StaticResource MainFont}" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="running">
                                                            <Setter Property="Foreground" Value="{StaticResource CrustBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="completed">
                                                            <Setter Property="Foreground" Value="{StaticResource CrustBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="failed">
                                                            <Setter Property="Foreground" Value="{StaticResource CrustBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="stopped">
                                                            <Setter Property="Foreground" Value="{StaticResource CrustBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Command Column -->
                        <GridViewColumn Header="Command" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Command}" Foreground="{StaticResource Subtext0Brush}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="4,2"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Actions Column -->
                        <GridViewColumn Header="" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Stop"
                                            Padding="8,3" FontSize="11"
                                            Command="{Binding DataContext.StopTaskCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="completed">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="failed">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="stopped">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.3"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ═══════ NEW TASK FORM ═══════ -->
        <Border Grid.Row="2" Margin="24,4,24,8" Background="{StaticResource Surface0Brush}"
                CornerRadius="8" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         Tag="Task name..."
                         Margin="0,0,8,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding NewTaskCommand, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         Tag="Command to run..."
                         Margin="0,0,8,0"/>

                <Button Grid.Column="2" Content="Start Task"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateTaskCommand}"
                        Padding="16,8"/>
            </Grid>
        </Border>

        <!-- ═══════ OUTPUT PANE ═══════ -->
        <Border Grid.Row="3" Margin="24,0,24,16" Background="{StaticResource CrustBrush}"
                CornerRadius="8" Padding="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Output header -->
                <Border Grid.Row="0" Padding="12,8" Background="{StaticResource MantleBrush}"
                        CornerRadius="8,8,0,0">
                    <TextBlock FontFamily="{StaticResource MainFont}" FontSize="12"
                               Foreground="{StaticResource Subtext0Brush}">
                        <Run Text="Output"/>
                        <Run Text=" - "/>
                        <Run Text="{Binding SelectedTask.Name, FallbackValue='(select a task)', Mode=OneWay}"
                             Foreground="{StaticResource TealBrush}"/>
                    </TextBlock>
                </Border>

                <!-- Output content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Style="{StaticResource SlimScrollViewer}">
                    <TextBox Text="{Binding SelectedTask.Output, Mode=OneWay, FallbackValue=''}"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Disabled"
                             Padding="12,8"
                             CaretBrush="{StaticResource TextBrush}"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
