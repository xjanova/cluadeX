<UserControl x:Class="CluadeX.Views.FeaturesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CluadeX.Converters"
             xmlns:vm="clr-namespace:CluadeX.ViewModels">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- Feature Card Style -->
        <Style x:Key="FeatureCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
            <Setter Property="Margin" Value="0,20,0,4"/>
        </Style>
        <Style x:Key="SectionDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Toggle Switch (simplified) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Cursor="Hand">
                            <Border x:Name="Track" Width="40" Height="22" CornerRadius="11"
                                    Background="{StaticResource Surface1Brush}"
                                    HorizontalAlignment="Left">
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White"
                                         HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource GreenBrush}"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="21,0,0,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource SlimScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24" MaxWidth="750">

            <!-- Page Title -->
            <TextBlock Text="{Binding PageTitle}" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       FontFamily="{StaticResource MainFont}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding PageSubtitle}"
                       Foreground="{StaticResource Subtext0Brush}" FontSize="13" Margin="0,0,0,4"/>

            <!-- ═══════ ACTIVATION KEY SECTION ═══════ -->
            <Border Background="{StaticResource Surface0Brush}" CornerRadius="12" Padding="18,14" Margin="0,8,0,4">
                <StackPanel>
                    <!-- Header row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔑" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Activation Key" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       FontFamily="{StaticResource MainFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Tier badge (when activated) -->
                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4"
                                Visibility="{Binding IsActivated, Converter={StaticResource BoolVis}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#A6E3A1" Offset="0"/>
                                    <GradientStop Color="#94E2D5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1E1E2E"
                                       FontFamily="{StaticResource MainFont}">
                                <Run Text="✅ "/>
                                <Run Text="{Binding ActivationTier, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Input row (when NOT activated) -->
                    <Grid Visibility="{Binding IsActivated, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource Surface1Brush}" CornerRadius="8" Padding="10,0">
                            <TextBox Text="{Binding ActivationKeyInput, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}"
                                     FontFamily="{StaticResource MainFont}" FontSize="13"
                                     Padding="0,8" VerticalAlignment="Center"
                                     CaretBrush="{StaticResource MauveBrush}"/>
                        </Border>
                        <Button Grid.Column="1" Content="Activate" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}" Padding="16,8"
                                Command="{Binding ActivateCommand}"/>
                    </Grid>

                    <!-- Deactivate button (when activated) -->
                    <Button Content="Deactivate" Margin="0,4,0,0" HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButton}" Padding="12,6"
                            Command="{Binding DeactivateCommand}"
                            Visibility="{Binding IsActivated, Converter={StaticResource BoolVis}}"/>

                    <!-- Status message -->
                    <TextBlock Text="{Binding ActivationMessage}" FontSize="12" Margin="0,6,0,0"
                               FontFamily="{StaticResource MainFont}" TextWrapping="Wrap"
                               Visibility="{Binding ActivationMessage, Converter={StaticResource BoolVis}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivationSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="Enter your activation key to unlock all advanced features. / ใส่คีย์เพื่อปลดล็อกฟีเจอร์ขั้นสูงทั้งหมด"
                               FontSize="10.5" Foreground="{StaticResource Overlay0Brush}"
                               FontFamily="{StaticResource MainFont}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Visibility="{Binding IsActivated, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"/>
                </StackPanel>
            </Border>

            <!-- ═══════ CORE FEATURES ═══════ -->
            <TextBlock Text="{Binding CoreLabel}" Style="{StaticResource SectionHeader}"
                       Foreground="{StaticResource GreenBrush}"/>
            <TextBlock Text="{Binding CoreDesc}" Style="{StaticResource SectionDesc}"/>

            <ItemsControl ItemsSource="{Binding CoreFeatures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FeatureCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource MainFont}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <CheckBox Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding IsEnabled}"
                                              IsEnabled="{Binding IsToggleable}"
                                              Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════ ADVANCED FEATURES ═══════ -->
            <TextBlock Text="{Binding AdvancedLabel}" Style="{StaticResource SectionHeader}"
                       Foreground="{StaticResource MauveBrush}"/>
            <TextBlock Text="{Binding AdvancedDesc}" Style="{StaticResource SectionDesc}"/>

            <ItemsControl ItemsSource="{Binding AdvancedFeatures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FeatureCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource MainFont}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" VerticalAlignment="Center"
                                        Background="{StaticResource Surface1Brush}"
                                        CornerRadius="8" Padding="8,4">
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                               Foreground="{StaticResource YellowBrush}"
                                               FontFamily="{StaticResource MainFont}"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════ AGENT TOOLS ═══════ -->
            <TextBlock Text="{Binding ToolsLabel}" Style="{StaticResource SectionHeader}"
                       Foreground="{StaticResource TealBrush}"/>
            <TextBlock Text="{Binding ToolsDesc}" Style="{StaticResource SectionDesc}"/>

            <ItemsControl ItemsSource="{Binding ToolFeatures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FeatureCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource MainFont}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <CheckBox Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding IsEnabled}"
                                              IsEnabled="{Binding IsToggleable}"
                                              Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════ SECURITY ═══════ -->
            <TextBlock Text="{Binding SecurityLabel}" Style="{StaticResource SectionHeader}"
                       Foreground="{StaticResource RedBrush}"/>
            <TextBlock Text="{Binding SecurityDesc}" Style="{StaticResource SectionDesc}"/>

            <ItemsControl ItemsSource="{Binding SecurityFeatures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FeatureCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource MainFont}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <CheckBox Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding IsEnabled}"
                                              IsEnabled="{Binding IsToggleable}"
                                              Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════ FUN & EXTRAS ═══════ -->
            <TextBlock Text="{Binding FunLabel}" Style="{StaticResource SectionHeader}"
                       Foreground="{StaticResource PinkBrush}"/>
            <TextBlock Text="{Binding FunDesc}" Style="{StaticResource SectionDesc}"/>

            <ItemsControl ItemsSource="{Binding FunFeatures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FeatureCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource MainFont}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               FontFamily="{StaticResource MainFont}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <CheckBox Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding IsEnabled}"
                                              IsEnabled="{Binding IsToggleable}"
                                              Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                               Foreground="{StaticResource Overlay0Brush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Height="20"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
