<Application x:Class="CluadeX.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CluadeX.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:NavItemConverter x:Key="NavConverter"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        </ResourceDictionary>
    </Application.Resources>

</Application>
