<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CATPPUCCIN MOCHA COLOR PALETTE                      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Color x:Key="CrustColor">#11111B</Color>
    <Color x:Key="MantleColor">#181825</Color>
    <Color x:Key="BaseColor">#1E1E2E</Color>
    <Color x:Key="Surface0Color">#313244</Color>
    <Color x:Key="Surface1Color">#45475A</Color>
    <Color x:Key="Surface2Color">#585B70</Color>
    <Color x:Key="Overlay0Color">#6C7086</Color>
    <Color x:Key="Overlay1Color">#7F849C</Color>
    <Color x:Key="Subtext0Color">#A6ADC8</Color>
    <Color x:Key="Subtext1Color">#BAC2DE</Color>
    <Color x:Key="TextColor">#CDD6F4</Color>
    <Color x:Key="BlueColor">#89B4FA</Color>
    <Color x:Key="LavenderColor">#B4BEFE</Color>
    <Color x:Key="SapphireColor">#74C7EC</Color>
    <Color x:Key="SkyColor">#89DCFE</Color>
    <Color x:Key="TealColor">#94E2D5</Color>
    <Color x:Key="GreenColor">#A6E3A1</Color>
    <Color x:Key="YellowColor">#F9E2AF</Color>
    <Color x:Key="PeachColor">#FAB387</Color>
    <Color x:Key="MaroonColor">#EBA0AC</Color>
    <Color x:Key="RedColor">#F38BA8</Color>
    <Color x:Key="MauveColor">#CBA6F7</Color>
    <Color x:Key="PinkColor">#F5C2E7</Color>
    <Color x:Key="RosewaterColor">#F5E0DC</Color>
    <Color x:Key="FlamColor">#F2CDCD</Color>

    <!-- Flat Brushes -->
    <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource CrustColor}"/>
    <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource MantleColor}"/>
    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}"/>
    <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0Color}"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="Overlay0Brush" Color="{StaticResource Overlay0Color}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Subtext0Brush" Color="{StaticResource Subtext0Color}"/>
    <SolidColorBrush x:Key="Subtext1Brush" Color="{StaticResource Subtext1Color}"/>
    <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource BlueColor}"/>
    <SolidColorBrush x:Key="LavenderBrush" Color="{StaticResource LavenderColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource MauveColor}"/>
    <SolidColorBrush x:Key="PeachBrush" Color="{StaticResource PeachColor}"/>
    <SolidColorBrush x:Key="TealBrush" Color="{StaticResource TealColor}"/>
    <SolidColorBrush x:Key="SapphireBrush" Color="{StaticResource SapphireColor}"/>
    <SolidColorBrush x:Key="Overlay1Brush" Color="{StaticResource Overlay1Color}"/>
    <SolidColorBrush x:Key="SkyBrush" Color="{StaticResource SkyColor}"/>
    <SolidColorBrush x:Key="PinkBrush" Color="{StaticResource PinkColor}"/>
    <SolidColorBrush x:Key="RosewaterBrush" Color="{StaticResource RosewaterColor}"/>
    <SolidColorBrush x:Key="MaroonBrush" Color="{StaticResource MaroonColor}"/>
    <SolidColorBrush x:Key="FlamBrush" Color="{StaticResource FlamColor}"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- 3D METALLIC GRADIENT BRUSHES                        -->
    <!-- ═══════════════════════════════════════════════════ -->
    <LinearGradientBrush x:Key="MetalSurface0" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3A3A50" Offset="0"/>
        <GradientStop Color="#2D2D42" Offset="0.4"/>
        <GradientStop Color="#282838" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalSurface1" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4E4E68" Offset="0"/>
        <GradientStop Color="#3E3E55" Offset="0.5"/>
        <GradientStop Color="#353548" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalBlueButton" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#A3C5FF" Offset="0"/>
        <GradientStop Color="#89B4FA" Offset="0.35"/>
        <GradientStop Color="#6E9AE8" Offset="0.85"/>
        <GradientStop Color="#5A87D8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalBlueHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#C5D6FF" Offset="0"/>
        <GradientStop Color="#B4BEFE" Offset="0.35"/>
        <GradientStop Color="#89A8F0" Offset="0.85"/>
        <GradientStop Color="#7A99E8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalSecondary" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#42425A" Offset="0"/>
        <GradientStop Color="#353548" Offset="0.5"/>
        <GradientStop Color="#2E2E40" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalSecondaryHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#545470" Offset="0"/>
        <GradientStop Color="#454560" Offset="0.5"/>
        <GradientStop Color="#3A3A50" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalCard" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#383850" Offset="0"/>
        <GradientStop Color="#313244" Offset="0.15"/>
        <GradientStop Color="#2C2C3E" Offset="0.95"/>
        <GradientStop Color="#272738" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MetalSidebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E1E30" Offset="0"/>
        <GradientStop Color="#181825" Offset="0.3"/>
        <GradientStop Color="#151520" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NavAccentGlow" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#89B4FA" Offset="0"/>
        <GradientStop Color="#B4BEFE" Offset="0.5"/>
        <GradientStop Color="#CBA6F7" Offset="1"/>
    </LinearGradientBrush>

    <!-- Nav — selected state: deep blue→mauve gradient, gives items real "lift" -->
    <LinearGradientBrush x:Key="NavCheckedFill" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2E3A5C" Offset="0"/>
        <GradientStop Color="#33305A" Offset="0.5"/>
        <GradientStop Color="#3C2A5A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Nav — hover: warmer, lighter sweep for contrast with default state -->
    <LinearGradientBrush x:Key="NavHoverFill" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2A2A40" Offset="0"/>
        <GradientStop Color="#30304A" Offset="0.5"/>
        <GradientStop Color="#2F2E48" Offset="1"/>
    </LinearGradientBrush>

    <!-- Icon bubble behind the glyph when the item is selected -->
    <LinearGradientBrush x:Key="NavIconBubble" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#89B4FA" Offset="0"/>
        <GradientStop Color="#CBA6F7" Offset="1"/>
    </LinearGradientBrush>

    <!-- Menu header: more visual weight than plain text — thin colored strip -->
    <LinearGradientBrush x:Key="MenuHeaderFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1E1E34" Offset="0"/>
        <GradientStop Color="#26263E" Offset="0.5"/>
        <GradientStop Color="#1E1E34" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource BlueColor}" Offset="0"/>
        <GradientStop Color="{StaticResource MauveColor}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TealGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource TealColor}" Offset="0"/>
        <GradientStop Color="{StaticResource SkyColor}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarmGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource PeachColor}" Offset="0"/>
        <GradientStop Color="{StaticResource PinkColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Shared Shadow Effects -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="4"
                      Direction="270" Color="#0A0A14" Opacity="0.6"/>
    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2"
                      Direction="270" Color="#0A0A14" Opacity="0.5"/>
    <DropShadowEffect x:Key="PopupShadow" BlurRadius="24" ShadowDepth="8"
                      Direction="270" Color="#08080F" Opacity="0.7"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY                                          -->
    <!-- ═══════════════════════════════════════════════════ -->
    <FontFamily x:Key="MainFont">Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SCROLLBAR                                           -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb>
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{StaticResource Surface2Brush}"
                                                            CornerRadius="4" Margin="1" Opacity="0.6"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0"/>
                        <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                   Style="{StaticResource SlimScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BUTTONS — 3D METALLIC                               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource MetalBlueButton}"/>
        <Setter Property="Foreground" Value="{StaticResource CrustBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="#55FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border CornerRadius="8,8,0,0" Height="1" VerticalAlignment="Top"
                                Background="#30FFFFFF" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MetalBlueHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#33FFFFFF"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource MetalSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="#18FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border CornerRadius="6,6,0,0" Height="1" VerticalAlignment="Top"
                                Background="#15FFFFFF" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MetalSecondaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
    </Style>

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            BorderThickness="1" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MetalSurface0}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#15FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- NAVIGATION — 3D METALLIC WITH ACCENT GLOW           -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Margin="2,1">
                        <!-- Left accent strip: shows only when selected -->
                        <Border x:Name="accentGlow" Width="3" HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0" Margin="0,4"
                                Background="{StaticResource NavAccentGlow}" Opacity="0"/>

                        <!-- Main card — gets lifted with a drop shadow when selected -->
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}" Margin="4,1"
                                BorderThickness="1" BorderBrush="Transparent">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="liftTransform" Y="0"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Colored bubble behind the icon when selected — gives depth + identity color -->
                                <Grid>
                                    <Ellipse x:Name="iconBubble" Width="26" Height="26"
                                             Fill="{StaticResource NavIconBubble}" Opacity="0"/>
                                    <TextBlock x:Name="icon" Text="{TemplateBinding Tag}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <!-- Subtle chevron on hover / selected for extra affordance -->
                                <TextBlock x:Name="chevron" Grid.Column="2"
                                           Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"
                                           Foreground="{StaticResource Overlay0Brush}"
                                           Opacity="0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource NavHoverFill}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#20FFFFFF"/>
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource BlueBrush}"/>
                            <Setter TargetName="chevron" Property="Opacity" Value="0.5"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource NavCheckedFill}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#3089B4FA"/>
                            <Setter TargetName="iconBubble" Property="Opacity" Value="0.25"/>
                            <Setter TargetName="icon" Property="Foreground" Value="#E0CBA6F7"/>
                            <Setter TargetName="icon" Property="FontSize" Value="16"/>
                            <Setter TargetName="accentGlow" Property="Opacity" Value="1"/>
                            <Setter TargetName="chevron" Property="Opacity" Value="1"/>
                            <Setter TargetName="chevron" Property="Foreground" Value="{StaticResource MauveBrush}"/>
                            <Setter Property="Foreground" Value="#F5E8FF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#89B4FA" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TEXTBOX — 3D INSET                                  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <Border CornerRadius="8,8,0,0" Height="1" VerticalAlignment="Top"
                                Background="#08000000" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- COMBOBOX — 3D METALLIC                              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ModernComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MetalSurface1}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MetalSurface1}"/>
                            <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource MetalSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#18FFFFFF"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource ModernComboBoxItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource Subtext0Brush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ToggleButton Grid.ColumnSpan="2" Opacity="0" Cursor="Hand"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Grid>
                        </Border>
                        <Border CornerRadius="8,8,0,0" Height="1" VerticalAlignment="Top"
                                Background="#12FFFFFF" IsHitTestVisible="False"/>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border Background="{StaticResource MetalCard}"
                                    BorderBrush="#20FFFFFF"
                                    BorderThickness="1" CornerRadius="8"
                                    Margin="0,4,0,0" Padding="4"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Effect="{StaticResource PopupShadow}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#28FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}"/>
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource ModernComboBoxItem}"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CHECKBOX — 3D METALLIC                              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ModernCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Grid>
                            <Border x:Name="checkBorder" Width="20" Height="20"
                                    CornerRadius="5"
                                    Background="{StaticResource MetalSecondary}"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="checkMark" Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource CrustBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkBorder" Property="Background" Value="{StaticResource MetalBlueButton}"/>
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="#44FFFFFF"/>
                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="#30FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox" BasedOn="{StaticResource ModernCheckBox}"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SLIDER — 3D METALLIC                                -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ModernSlider" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="6" CornerRadius="3" Background="{StaticResource MetalSecondary}"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="{StaticResource MetalBlueButton}" Height="6" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="thumb" Width="20" Height="20" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid>
                                                <Ellipse x:Name="thumbEllipse"
                                                         Fill="{StaticResource MetalBlueButton}"
                                                         Width="20" Height="20"
                                                         Stroke="#44FFFFFF" StrokeThickness="1"/>
                                                <Ellipse Width="14" Height="8" VerticalAlignment="Top"
                                                         Margin="0,2,0,0" IsHitTestVisible="False">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush>
                                                            <GradientStop Color="#40FFFFFF" Offset="0"/>
                                                            <GradientStop Color="Transparent" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="thumbEllipse" Property="Fill" Value="{StaticResource MetalBlueHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="thumbEllipse" Property="Width" Value="22"/>
                                                    <Setter TargetName="thumbEllipse" Property="Height" Value="22"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Slider" BasedOn="{StaticResource ModernSlider}"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- PROGRESS BAR — 3D                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource MetalSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource MetalBlueButton}"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="3"
                            BorderThickness="1" BorderBrush="#10000000">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CARD — 3D METALLIC WITH DROP SHADOW                 -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MetalCard}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#12FFFFFF"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TOOLTIP — 3D                                        -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource MetalSurface1}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#20FFFFFF"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- WINDOW CAPTION BUTTONS                              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource MetalSurface1}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Surface2Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionCloseButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource RedBrush}"/>
                            <Setter Property="Foreground">
                                <Setter.Value><SolidColorBrush Color="White"/></Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background">
                                <Setter.Value><SolidColorBrush Color="#CC3333"/></Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CONTEXT PROGRESS BAR                                -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ContextProgressBar" TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource MetalSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource TealBrush}"/>
        <Setter Property="Height" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="2"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- EXPANDER — 3D                                       -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="ToolExpander" TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <ToggleButton x:Name="HeaderSite"
                                      Content="{TemplateBinding Header}"
                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="hdrBorder" Background="Transparent"
                                            CornerRadius="4" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="arrow" Text="&#xE76C;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                       Foreground="{StaticResource Overlay0Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform Angle="0"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <ContentPresenter/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="arrow" Property="RenderTransform">
                                                <Setter.Value><RotateTransform Angle="90"/></Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="hdrBorder" Property="Background" Value="{StaticResource MetalSurface0}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SESSION LIST ITEM — 3D                              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="SessionItemButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Subtext0Brush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="4,1"
                            BorderThickness="1" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Stretch"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource MetalSurface0}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="#10FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource MetalSurface1}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BADGE                                               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Background" Value="{StaticResource MetalSurface1}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#10FFFFFF"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CODE BLOCK — 3D                                     -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="CodeBlock" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#151520" Offset="0"/>
                    <GradientStop Color="#11111B" Offset="0.3"/>
                    <GradientStop Color="#0E0E16" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#15FFFFFF"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- GLOW TEXTBOX — 3D                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="GlowTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="glow" CornerRadius="8" Opacity="0"
                                BorderThickness="1" BorderBrush="{StaticResource BlueBrush}">
                            <Border.Effect>
                                <BlurEffect Radius="8"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <Border CornerRadius="8,8,0,0" Height="1" VerticalAlignment="Top"
                                Background="#08000000" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
                            <Setter TargetName="glow" Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
