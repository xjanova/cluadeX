#include <windows.h>
#include "resource.h"

// Note: manifest is embedded by the linker via /manifest:embed, not from .rc
// The app.manifest file is referenced in the vcxproj instead.

// ── Setup Dialog ─────────────────────────────────────────────────────
IDD_SETUP DIALOGEX 0, 0, 340, 240
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "CluadeX - Setup"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Welcome! Choose your server mode and configure below.",
                    -1, 14, 10, 310, 12

    GROUPBOX        "Server Mode", -1, 14, 26, 310, 36
    AUTORADIOBUTTON "Cloud (Anthropic API)", IDC_MODE_CLOUD, 24, 40, 120, 12,
                    WS_GROUP
    AUTORADIOBUTTON "Local (Ollama)", IDC_MODE_LOCAL, 160, 40, 120, 12

    LTEXT           "API Key:", -1, 14, 74, 55, 10
    EDITTEXT        IDC_API_KEY, 80, 72, 244, 14,
                    ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Endpoint:", -1, 14, 96, 55, 10
    EDITTEXT        IDC_LOCAL_ENDPOINT, 80, 94, 244, 14, ES_AUTOHSCROLL

    LTEXT           "Model:", -1, 14, 118, 55, 10
    COMBOBOX        IDC_MODEL, 80, 116, 200, 120,
                    CBS_DROPDOWNLIST | WS_VSCROLL
    PUSHBUTTON      "...", IDC_REFRESH_MODELS, 286, 116, 22, 14

    PUSHBUTTON      "Test Connection", IDC_TEST_CONN, 80, 142, 90, 16
    LTEXT           "", IDC_SETUP_STATUS, 178, 144, 146, 10

    GROUPBOX        "Status", -1, 14, 164, 310, 32
    LTEXT           "Not configured.", IDC_STATUS, 24, 178, 290, 12

    DEFPUSHBUTTON   "Save && Start", IDC_SAVE, 186, 208, 72, 18
    PUSHBUTTON      "Cancel", IDCANCEL, 264, 208, 56, 18
END

// ── Settings Dialog ──────────────────────────────────────────────────
IDD_SETTINGS DIALOGEX 0, 0, 360, 310
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX        "Server Mode", -1, 14, 8, 330, 36
    AUTORADIOBUTTON "Cloud (Anthropic API)", IDC_MODE_CLOUD, 24, 22, 120, 12,
                    WS_GROUP
    AUTORADIOBUTTON "Local (Ollama)", IDC_MODE_LOCAL, 160, 22, 120, 12

    LTEXT           "API Key:", -1, 14, 56, 60, 10
    EDITTEXT        IDC_API_KEY, 80, 54, 264, 14,
                    ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Endpoint:", -1, 14, 78, 60, 10
    EDITTEXT        IDC_LOCAL_ENDPOINT, 80, 76, 264, 14, ES_AUTOHSCROLL

    LTEXT           "Model:", -1, 14, 100, 60, 10
    COMBOBOX        IDC_MODEL, 80, 98, 220, 120,
                    CBS_DROPDOWNLIST | WS_VSCROLL
    PUSHBUTTON      "...", IDC_REFRESH_MODELS, 306, 98, 22, 14

    LTEXT           "Max Tokens:", -1, 14, 122, 60, 10
    EDITTEXT        IDC_MAX_TOKENS, 80, 120, 60, 14, ES_NUMBER

    LTEXT           "Temperature:", -1, 14, 144, 60, 10
    EDITTEXT        IDC_TEMPERATURE, 80, 142, 60, 14

    LTEXT           "System Prompt:", -1, 14, 166, 60, 10
    EDITTEXT        IDC_SYSTEM_PROMPT, 80, 164, 264, 80,
                    ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    PUSHBUTTON      "Test Connection", IDC_TEST_CONN, 80, 256, 90, 16
    LTEXT           "", IDC_SETUP_STATUS, 178, 258, 166, 10

    DEFPUSHBUTTON   "Save", IDC_SAVE, 234, 284, 56, 18
    PUSHBUTTON      "Cancel", IDCANCEL, 296, 284, 48, 18
END

// ── Model Manager Dialog ─────────────────────────────────────────────
IDD_MODELMANAGER DIALOGEX 0, 0, 540, 480
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Model Manager - CluadeX"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Installed Models:", -1, 10, 8, 80, 10
    LISTBOX         IDC_MODEL_LIST, 10, 20, 200, 100,
                    LBS_NOTIFY | WS_VSCROLL | LBS_NOINTEGRALHEIGHT
    PUSHBUTTON      "Delete Selected", IDC_MODEL_DELETE, 10, 124, 80, 16

    GROUPBOX        "Pull from Ollama Library", -1, 220, 8, 310, 52
    LTEXT           "Name:", -1, 228, 24, 28, 10
    EDITTEXT        IDC_OLLAMA_NAME, 258, 22, 226, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Pull", IDC_OLLAMA_PULL, 490, 22, 32, 14
    LTEXT           "e.g. llama3.2:3b, mistral:7b, codellama:7b",
                    -1, 228, 42, 200, 10

    GROUPBOX        "Pull from Hugging Face", -1, 220, 68, 310, 72
    LTEXT           "HF Repo:", -1, 228, 84, 40, 10
    EDITTEXT        IDC_HF_REPO, 270, 82, 252, 14, ES_AUTOHSCROLL
    LTEXT           "Quant:", -1, 228, 104, 30, 10
    COMBOBOX        IDC_HF_QUANT, 270, 102, 140, 100,
                    CBS_DROPDOWNLIST | WS_VSCROLL
    PUSHBUTTON      "Pull", IDC_HF_PULL, 490, 102, 32, 14
    LTEXT           "e.g. bartowski/Llama-3.2-3B-Instruct-GGUF",
                    -1, 228, 124, 280, 10

    GROUPBOX        "Import from GGUF File", -1, 10, 148, 520, 42
    LTEXT           "GGUF:", -1, 18, 164, 28, 10
    EDITTEXT        IDC_GGUF_PATH, 48, 162, 240, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_GGUF_BROWSE, 292, 162, 22, 14
    LTEXT           "Name:", -1, 322, 164, 28, 10
    EDITTEXT        IDC_GGUF_NAME, 352, 162, 126, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Import", IDC_GGUF_IMPORT, 484, 162, 38, 14

    GROUPBOX        "Popular Models (click to install)", -1, 10, 196, 520, 130
    LTEXT           "Filter:", -1, 18, 212, 28, 10
    COMBOBOX        1183, 48, 210, 100, 80,
                    CBS_DROPDOWNLIST | WS_VSCROLL
    LISTBOX         1180, 18, 228, 410, 90,
                    LBS_NOTIFY | WS_VSCROLL | LBS_NOINTEGRALHEIGHT
    PUSHBUTTON      "Install Selected", 1181, 434, 228, 88, 16
    LTEXT           "", 1182, 434, 250, 88, 68

    GROUPBOX        "Status", -1, 10, 332, 520, 110
    EDITTEXT        IDC_MODEL_STATUS, 18, 346, 504, 88,
                    ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL

    PUSHBUTTON      "Close", IDCANCEL, 474, 452, 56, 18
END

// ── Run Command Dialog ───────────────────────────────────────────────
IDD_RUNCMD DIALOGEX 0, 0, 420, 300
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
        | WS_THICKFRAME
CAPTION "Run Command"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Command:", -1, 10, 10, 40, 10
    EDITTEXT        1150, 56, 8, 290, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "Run", 1152, 354, 7, 52, 16

    LTEXT           "Output:", -1, 10, 30, 40, 10
    EDITTEXT        1151, 10, 42, 396, 244,
                    ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL
                    | ES_AUTOHSCROLL | WS_HSCROLL
END
